 773      sobra(i) = 0 )
 774  );
 775   
 776   
 777  loop(i$( sh.l(i) gt 3e-2 ),
 778      loop(j$( (sh.l(j) gt 3e-2) and (conecta(j) lt 1) and (a.l(i,j) gt 1e-3) ),
 779      sobra(i) = 0 )
 780  );
 781   
 782   
 783  sh.fx(i)$((sobra(i)=1) and iter > 1)=0;
