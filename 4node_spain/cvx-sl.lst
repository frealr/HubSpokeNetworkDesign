 310  Scalars tau, sigma, a_nom, a_max;
 311  tau = 0.85;
 312  sigma = 0.3;
 313  a_nom = 171;
 314  a_max = 1e7;
 315   
 316  Scalar n; n = card(i);
 317   
 318  Scalar epsi; epsi = 1e-3;
