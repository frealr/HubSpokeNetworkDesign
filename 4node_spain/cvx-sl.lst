 308   
 309  Scalars tau, sigma, a_nom, a_max;
 310  tau = 0.85;
 311  sigma = 0.3;
 312  a_nom = 171;
 313  a_max = 1e7;
 314   
 315  Scalar n; n = card(i);
 316   
 317  Scalar epsi; epsi = 1e-3;
 318   
