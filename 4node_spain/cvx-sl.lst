 353  display travel_time,link_cost,link_capacity_slope,prices,candidates,station_cost,station_capacity_slope,a_max, iter, niters, demand;
 354   
 355   
 356  *---------------------*
 357  * Variables           *
 358  *---------------------*
 359   
 360   
 361  Nonnegative Variable
 362      s(i),     sh(i),
 363      a(i,j),
 364      f(o,d),      fext(o,d), f_aux(o,d), fext_aux(o,d),
 365      fij(i,j,o,d), exceed
 366      ;
 367   
 368  Variable bud, op, pax, obj, ft(o,d),ftext(o,d),fr(o,d),frext(o,d),fy(o,d),fyext(o,d),ul;
 369   
 370   
 371   
 372  *---------------------*
 373  * Ecuaciones          *
 374  *---------------------*
 375  Equation
 376      bud_def      "definición de bud_obj"
 377      op_def       "definición de op_obj"
 378      pax_def      "definición de pax_obj"
 379      obj_def      "objetivo total"
 380      ul_def
 381   
 382      def_f_aux
 383      def_fext_aux
 384   
 385      link_sym(i,j)
 386      prim_s_def(i)
 387      prim_a_def(i,j)
 388   
 389      link_cap(i,j)
 390      station_cap(i)
 391      hub_connect_cap(i)
 392      hub_direct_cap(o,d)
 393   
 394      tot_links
 395      link_flow_to_f(o,d)
 396   
 397      profitability(o,d)
 398   
 399      bud_avail
 400      bud_final
 401   
 402      flow_start(o,d)     "conservación en origen o para cada destino d != o"
 403      flow_end(o,d)       "conservación en destino d para cada origen o != d"
 404      flow_mid(i,o,d)     "conservación en nodos intermedios i != o,d"
 405   
 406      zero_diag_od(o)
 407      zero_fij_self(i,o,d)
 408      zero_fij_origin(o,i,d)
 409      zero_fij_dest(d,i,o)
 410      zero_diag_odext
 411   
 412      split_choice(o,d)
 413      candidates_zero(i,j)
 414   
 415      fix_s_at_zero(i)
 416      fix_sh_at_zero(i)
 417   
 418      expconef(o,d)
 419      exponefext(o,d)
 420      epigraphf(o,d)
 421      epigraphfext(o,d)
 422   
 423      def_deltasaux(i)
 424      def_deltaaaux(i,j)
 425      powercones(i)
 426      powerconea(i,j)
 427      f_bounds_logit(o,d)
 428   
 429      station_cap_first_iter(i)
 430   
 431  *rescap
 432  ;
 433   
 434  *---------------------*
 435  * Definición objetivo *
 436  *---------------------*
 437   
 438  ul_def..
 439      ul =e= 1e-2*(-sum((o,d)$(ord(o) ne ord(d)),prices(o,d)*demand(o,d)*f(o,d) ) + sum((i,j), op_link_cost(i,j) * a(i,j))) ;
 440   
 441   
 442  * Presupuesto (bud): costes lineales + (si iter<niters) costes fijos aproximados
 443  bud_def..
 444      bud =e= sum(i, station_capacity_slope(i)*(s(i) + 1.01*sh(i)))
 445           + sum(i,
 446                          station_cost(i)*(s(i)+1.01*sh(i))/((s_prev(i)+sh_prev(i))+epsi))
 447           + sum(i,
 448                          lam*hub_cost(i)*sh(i)/(sh_prev(i)+epsi));
 449   
 450   
 451   
 452   
 453   
 454  * Operación (op): coste lineal de operar enlaces
 455  op_def..
 456      op =e= 1e-3*sum((i,j), op_link_cost(i,j) * a(i,j));
 457   
 458  * Pasajeros (pax): tiempos/precios en ruta y alternativas + entropías
 459  pax_def..
 460      pax =e= 1e-2*(
 461        sum((o,d)$(ord(o) ne ord(d)),
 462              alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *
 463             ( logit_coef*prices(o,d)*f(o,d) + sum((i,j), travel_time(i,j)*fij(i,j,o,d)*logit_coef)))
 464   
 465      - sum((o,d)$(ord(o) ne ord(d)), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d)
 466            * alt_utility(o,d)*fext(o,d))
 467   
 468      + sum((o,d)$(ord(o) ne ord(d)),alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) * (ft(o,d)))
 469  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
 470   
 471     + sum((o,d)$(ord(o) ne ord(d)), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *(ftext(o,d)
 472     - fext_aux(o,d)*log(n_airlines))) )
 473   
 474   
 475   
 476   
 477  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
 478   
 479  *    + 1e-3*sum((o,d), demand(o,d)
 480  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
 481   
 482  *   + 1e-3*sum((o,d), demand(o,d)
 483  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
 484  *    +1e-3*sum(i,deltast(i))
 485  *  + 1e-3*sum(i,
 486  *         1/(congestion_coefs_stations(i)*deltas(i) + epsi))
 487  *    +1e-3*sum((i,j),deltaat(i,j))
 488  *    + 1e-3*sum((i,j),
 489  *          1/(congestion_coefs_links(i,j)*deltaa(i,j) + epsi))
 490  ;
 491   
 492  * Objetivo total
 493  obj_def..
 494      obj =e= ul + 5e-2*gamma_*(pax + op + 1e3*exceed + 1e-6*bud);
 495   
 496  *---------------------*
 497  * Restricciones       *
 498  *---------------------*
 499   
 500   
 501  bud_avail..
 502      bud =l= budget;
 503   
 504  bud_final..
 505      ( sum(i, station_capacity_slope(i)*(s(i) + sh(i)))   + sum(i$((s_prev(i) > 0.01) or (sh_prev(i) > 0.01)), station_cost(i))
 506    + sum(i$(sh_prev(i) > 0.01), lam*hub_cost(i)))$(iter = niters) - exceed
 507      =l=
 508      budget
 509  ;
 510   
 511   
 512  profitability(o,d).. demand(o,d)*prices(o,d)*f(o,d) =g= sum((i,j),demand(o,d)*fij(i,j,o,d)*op_link_cost(i,j)/(a_nom*tau));
 513   
 514  * Simetría de a_prim
 515  link_sym(i,j)$(ord(i) ne ord(j))..  a(i,j) =e= a(j,i);
 516   
 517  * Capacidad de enlace: sum_{o,d} fij(i,j,o,d)*demand(o,d) <= tau*a(i,j)*a_nom
 518  link_cap(i,j)..
 519      sum((o,d), fij(i,j,o,d)*demand(o,d)) =l= a(i,j)*a_nom*tau;
 520   
 521   
 522   
 523  station_cap(i)..   sigma * (sum(j, a(j,i)) + sum(j, a(i,j))) =l= s(i) + sh(i);
 524   
 525  station_cap_first_iter(i)$(iter <= 1).. sigma * (sum(j, a(j,i)) + sum(j, a(i,j))) =l= sh(i);
 526   
 527  hub_connect_cap(i).. sigma * (sum( (o,d,j)$(ord(o)<>ord(i)),
 528      demand(o,d) * fij(i,j,o,d) / (a_nom * tau))  + sum( (o,d,j)$(ord(d)<>ord(i)),
 529      demand(o,d) * fij(j,i,o,d) / (a_nom * tau))) =l= sh(i);
 530   
 531   
 532  hub_direct_cap(o,d).. sigma * demand(o,d) * fij(o,d,o,d) / (a_nom * tau) =l= sh(o) + sh(d);
 533   
 534   
 535  * Límite total de links construidos/operativos
 536  tot_links..
 537      sum((i,j), a(i,j)) =l= a_max;
 538   
 539  * Relación f con flujos saliendo del origen
 540  link_flow_to_f(o,d)..
 541      sum(j, fij(o,j,o,d)) =e= f(o,d);
 542   
 543  * Conservación en nodos de origen (para k!=o): sum_out - sum_in = 1 - fext(o,k)
 544  flow_start(o,d)$(ord(o) ne ord(d))..
 545      ( sum(j, fij(o,j,o,d)) - sum(i, fij(i,o,o,d)) ) =e= 1 - fext(o,d);
 546   
 547  * Conservación en nodos destino (para k!=d): sum_out - sum_in = -1 + fext(k,d)
 548  flow_end(o,d)$(ord(o) ne ord(d))..
 549      ( sum(j, fij(d,j,o,d)) - sum(i, fij(i,d,o,d)) ) =e= -1 + fext(o,d);
 550   
 551  * Conservación en nodos intermedios i != o,d: sum_out - sum_in = 0
 552  flow_mid(i,o,d)$( (ord(o) ne ord(i)) and (ord(i) ne ord(d)) )..
 553      ( sum(j, fij(i,j,o,d)) - sum(j, fij(j,i,o,d)) ) =e= 0;
 554   
 555  * Zeros en diagonal y bloques prohibidos (replican fij(:,o,o,:) == 0, etc.)
 556  zero_diag_od(o)..           f(o,o)    =l= epsi;
 557  * fext(o,o)=0:
 558  zero_diag_odext(o)..           fext(o,o)    =l= epsi;
 559   
 560  * fij(i,i,*,*) = 0
 561  zero_fij_self(i,o,d)..      fij(i,i,o,d) =l= epsi;
 562   
 563  * fij(:,o,o,:) = 0  -> i cualquiera, j=o, o=o, d cualquiera
 564  zero_fij_origin(o,i,d)..    fij(i,o,o,d) =l= epsi;
 565   
 566  * fij(d,:,:,d) = 0  -> i=d, j cualquiera, o cualquiera, d=d
 567  zero_fij_dest(d,i,o)..      fij(d,i,o,d) =l= epsi;
 568   
 569  * Split: para o!=d, f + fext = 1
 570  split_choice(o,d)$(ord(o) ne ord(d))..
 571      f(o,d) + fext(o,d) =e= 1;
 572   
 573  * Enlaces no candidatesidatos forzados a 0: a_prim(i,j)=0 si ~(i,j) en candidates
 574  candidates_zero(i,j)$(not candidates(i,j))..
 575      a(i,j) =e= 0;
 576   
 577  * Fijaciones en la iteración final si previos pequeños (replica iter==niters … <=0.1)
 578  fix_s_at_zero(i)$( (s_prev(i) <= 0.01) and (iter = niters) )..
 579      s(i) =l= epsi;
 580   
 581  fix_sh_at_zero(i)$( (sh_prev(i) <= 0.01) and (iter = niters) )..
 582      sh(i) =l= epsi;
 583   
 584   
 585  def_f_aux(o,d).. f_aux(o,d) =e= f(o,d) + epsi_f;
 586  def_fext_aux(o,d).. fext_aux(o,d) =e= fext(o,d) + epsi_f;
 587   
 588   
 589  expconef(o,d)..  fy(o,d) =g= f_aux(o,d)*exp(fr(o,d)/f_aux(o,d));
 590   
 591   
 592  exponefext(o,d)..  fyext(o,d) =g= fext_aux(o,d)*exp(frext(o,d)/fext_aux(o,d));
 593   
 594  epigraphf(o,d)..  ft(o,d) =g= -fr(o,d)-f_aux(o,d);
 595   
 596  epigraphfext(o,d)..  ftext(o,d) =g= -frext(o,d)-fext_aux(o,d);
 597   
 598   
 599  f_bounds_logit(o,d).. f(o,d) =l= f_bounds(o,d);
 600  *rescap(i,j,o,d).. fij(i,j,o,d) =l= capa(i,j);
 601   
 602  *---------------------*
 603  * Bounds básicas      *
 604  *---------------------*
 605  * Ya son positivas; si quieres forzar [0,1] también para f,fext,fij ya está con .up=1
 606  * Para a, s, etc., sin cota superior explícita (ajústalas si procede)
 607   
