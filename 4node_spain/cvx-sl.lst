 354  display travel_time,link_cost,link_capacity_slope,prices,candidates,station_cost,station_capacity_slope,a_max, iter, niters, demand;
 355   
 356   
 357  *---------------------*
 358  * Variables           *
 359  *---------------------*
 360   
 361   
 362  Nonnegative Variable
 363      s(i),     sh(i),
 364      a(i,j),
 365      f(o,d),      fext(o,d), f_aux(o,d), fext_aux(o,d),
 366      fij(i,j,o,d), exceed
 367      ;
 368   
 369  Variable bud, op, pax, obj, ft(o,d),ftext(o,d),fr(o,d),frext(o,d),fy(o,d),fyext(o,d),ul;
 370   
 371   
 372   
 373  *---------------------*
 374  * Ecuaciones          *
 375  *---------------------*
 376  Equation
 377      bud_def      "definición de bud_obj"
 378      op_def       "definición de op_obj"
 379      pax_def      "definición de pax_obj"
 380      obj_def      "objetivo total"
 381      ul_def
 382   
 383      def_f_aux
 384      def_fext_aux
 385   
 386      link_sym(i,j)
 387      prim_s_def(i)
 388      prim_a_def(i,j)
 389   
 390      link_cap(i,j)
 391      station_cap(i)
 392      hub_connect_cap(i)
 393      hub_direct_cap(o,d)
 394   
 395      tot_links
 396      link_flow_to_f(o,d)
 397   
 398      profitability(o,d)
 399   
 400      bud_avail
 401      bud_final
 402   
 403      flow_start(o,d)     "conservación en origen o para cada destino d != o"
 404      flow_end(o,d)       "conservación en destino d para cada origen o != d"
 405      flow_mid(i,o,d)     "conservación en nodos intermedios i != o,d"
 406   
 407      zero_diag_od(o)
 408      zero_fij_self(i,o,d)
 409      zero_fij_origin(o,i,d)
 410      zero_fij_dest(d,i,o)
 411      zero_diag_odext
 412   
 413      split_choice(o,d)
 414      candidates_zero(i,j)
 415   
 416      fix_s_at_zero(i)
 417      fix_sh_at_zero(i)
 418   
 419      expconef(o,d)
 420      exponefext(o,d)
 421      epigraphf(o,d)
 422      epigraphfext(o,d)
 423   
 424      def_deltasaux(i)
 425      def_deltaaaux(i,j)
 426      powercones(i)
 427      powerconea(i,j)
 428      f_bounds_logit(o,d)
 429   
 430      station_cap_first_iter(i)
 431   
 432  *rescap
 433  ;
 434   
 435  *---------------------*
 436  * Definición objetivo *
 437  *---------------------*
 438   
 439  ul_def..
 440      ul =e= 1e-2*(-sum((o,d)$(ord(o) ne ord(d)),prices(o,d)*demand(o,d)*f(o,d) ) + sum((i,j), op_link_cost(i,j) * a(i,j))) ;
 441   
 442   
 443  * Presupuesto (bud): costes lineales + (si iter<niters) costes fijos aproximados
 444  bud_def..
 445      bud =e= sum(i, station_capacity_slope(i)*(s(i) + 1.01*sh(i)))
 446           + sum(i,
 447                          station_cost(i)*(s(i)+1.01*sh(i))/((s_prev(i)+sh_prev(i))+epsi))
 448           + sum(i,
 449                          lam*hub_cost(i)*sh(i)/(sh_prev(i)+epsi));
 450   
 451   
 452   
 453   
 454   
 455  * Operación (op): coste lineal de operar enlaces
 456  op_def..
 457      op =e= 1e-3*sum((i,j), op_link_cost(i,j) * a(i,j));
 458   
 459  * Pasajeros (pax): tiempos/precios en ruta y alternativas + entropías
 460  pax_def..
 461      pax =e= 1e-2*(
 462        sum((o,d)$(ord(o) ne ord(d)),
 463              alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *
 464             ( logit_coef*prices(o,d)*f(o,d) + sum((i,j), travel_time(i,j)*fij(i,j,o,d)*logit_coef)))
 465   
 466      - sum((o,d)$(ord(o) ne ord(d)), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d)
 467            * alt_utility(o,d)*fext(o,d))
 468   
 469      + sum((o,d)$(ord(o) ne ord(d)),alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) * (ft(o,d)))
 470  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
 471   
 472     + sum((o,d)$(ord(o) ne ord(d)), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *(ftext(o,d)
 473     - fext_aux(o,d)*log(n_airlines))) )
 474   
 475   
 476   
 477   
 478  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
 479   
 480  *    + 1e-3*sum((o,d), demand(o,d)
 481  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
 482   
 483  *   + 1e-3*sum((o,d), demand(o,d)
 484  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
 485  *    +1e-3*sum(i,deltast(i))
 486  *  + 1e-3*sum(i,
 487  *         1/(congestion_coefs_stations(i)*deltas(i) + epsi))
 488  *    +1e-3*sum((i,j),deltaat(i,j))
 489  *    + 1e-3*sum((i,j),
 490  *          1/(congestion_coefs_links(i,j)*deltaa(i,j) + epsi))
 491  ;
 492   
 493  * Objetivo total
 494  obj_def..
 495      obj =e= ul + 5e-2*gamma_*(pax + op + 1e3*exceed + 1e-6*bud);
 496   
 497  *---------------------*
 498  * Restricciones       *
 499  *---------------------*
 500   
 501   
 502  bud_avail..
 503      bud =l= budget;
 504   
 505  bud_final..
 506      ( sum(i, station_capacity_slope(i)*(s(i) + sh(i)))   + sum(i$((s_prev(i) > 0.01) or (sh_prev(i) > 0.01)), station_cost(i))
 507    + sum(i$(sh_prev(i) > 0.01), lam*hub_cost(i)))$(iter = niters) - exceed
 508      =l=
 509      budget
 510  ;
 511   
 512   
 513  profitability(o,d).. demand(o,d)*prices(o,d)*f(o,d) =g= sum((i,j),demand(o,d)*fij(i,j,o,d)*op_link_cost(i,j)/(a_nom*tau));
 514   
 515  * Simetría de a_prim
 516  link_sym(i,j)$(ord(i) ne ord(j))..  a(i,j) =e= a(j,i);
 517   
 518  * Capacidad de enlace: sum_{o,d} fij(i,j,o,d)*demand(o,d) <= tau*a(i,j)*a_nom
 519  link_cap(i,j)..
 520      sum((o,d), fij(i,j,o,d)*demand(o,d)) =l= a(i,j)*a_nom*tau;
 521   
 522   
 523   
 524  station_cap(i)..   sigma * (sum(j, a(j,i)) + sum(j, a(i,j))) =l= s(i) + sh(i);
 525   
 526  station_cap_first_iter(i)$(iter <= 1).. sigma * (sum(j, a(j,i)) + sum(j, a(i,j))) =l= sh(i);
 527   
 528  hub_connect_cap(i).. sigma * (sum( (o,d,j)$(ord(o)<>ord(i)),
 529      demand(o,d) * fij(i,j,o,d) / (a_nom * tau))  + sum( (o,d,j)$(ord(d)<>ord(i)),
 530      demand(o,d) * fij(j,i,o,d) / (a_nom * tau))) =l= sh(i);
 531   
 532   
 533  hub_direct_cap(o,d).. sigma * demand(o,d) * fij(o,d,o,d) / (a_nom * tau) =l= sh(o) + sh(d);
 534   
 535   
 536  * Límite total de links construidos/operativos
 537  tot_links..
 538      sum((i,j), a(i,j)) =l= a_max;
 539   
 540  * Relación f con flujos saliendo del origen
 541  link_flow_to_f(o,d)..
 542      sum(j, fij(o,j,o,d)) =e= f(o,d);
 543   
 544  * Conservación en nodos de origen (para k!=o): sum_out - sum_in = 1 - fext(o,k)
 545  flow_start(o,d)$(ord(o) ne ord(d))..
 546      ( sum(j, fij(o,j,o,d)) - sum(i, fij(i,o,o,d)) ) =e= 1 - fext(o,d);
 547   
 548  * Conservación en nodos destino (para k!=d): sum_out - sum_in = -1 + fext(k,d)
 549  flow_end(o,d)$(ord(o) ne ord(d))..
 550      ( sum(j, fij(d,j,o,d)) - sum(i, fij(i,d,o,d)) ) =e= -1 + fext(o,d);
 551   
 552  * Conservación en nodos intermedios i != o,d: sum_out - sum_in = 0
 553  flow_mid(i,o,d)$( (ord(o) ne ord(i)) and (ord(i) ne ord(d)) )..
 554      ( sum(j, fij(i,j,o,d)) - sum(j, fij(j,i,o,d)) ) =e= 0;
 555   
 556  * Zeros en diagonal y bloques prohibidos (replican fij(:,o,o,:) == 0, etc.)
 557  zero_diag_od(o)..           f(o,o)    =l= epsi;
 558  * fext(o,o)=0:
 559  zero_diag_odext(o)..           fext(o,o)    =l= epsi;
 560   
 561  * fij(i,i,*,*) = 0
 562  zero_fij_self(i,o,d)..      fij(i,i,o,d) =l= epsi;
 563   
 564  * fij(:,o,o,:) = 0  -> i cualquiera, j=o, o=o, d cualquiera
 565  zero_fij_origin(o,i,d)..    fij(i,o,o,d) =l= epsi;
 566   
 567  * fij(d,:,:,d) = 0  -> i=d, j cualquiera, o cualquiera, d=d
 568  zero_fij_dest(d,i,o)..      fij(d,i,o,d) =l= epsi;
 569   
 570  * Split: para o!=d, f + fext = 1
 571  split_choice(o,d)$(ord(o) ne ord(d))..
 572      f(o,d) + fext(o,d) =e= 1;
 573   
 574  * Enlaces no candidatesidatos forzados a 0: a_prim(i,j)=0 si ~(i,j) en candidates
 575  candidates_zero(i,j)$(not candidates(i,j))..
 576      a(i,j) =e= 0;
 577   
 578  * Fijaciones en la iteración final si previos pequeños (replica iter==niters … <=0.1)
 579  fix_s_at_zero(i)$( (s_prev(i) <= 0.01) and (iter = niters) )..
 580      s(i) =l= epsi;
 581   
 582  fix_sh_at_zero(i)$( (sh_prev(i) <= 0.01) and (iter = niters) )..
 583      sh(i) =l= epsi;
 584   
 585   
 586  def_f_aux(o,d).. f_aux(o,d) =e= f(o,d) + epsi_f;
 587  def_fext_aux(o,d).. fext_aux(o,d) =e= fext(o,d) + epsi_f;
 588   
 589   
 590  expconef(o,d)..  fy(o,d) =g= f_aux(o,d)*exp(fr(o,d)/f_aux(o,d));
 591   
 592   
 593  exponefext(o,d)..  fyext(o,d) =g= fext_aux(o,d)*exp(frext(o,d)/fext_aux(o,d));
 594   
 595  epigraphf(o,d)..  ft(o,d) =g= -fr(o,d)-f_aux(o,d);
 596   
 597  epigraphfext(o,d)..  ftext(o,d) =g= -frext(o,d)-fext_aux(o,d);
 598   
 599   
 600  f_bounds_logit(o,d).. f(o,d) =l= f_bounds(o,d);
 601  *rescap(i,j,o,d).. fij(i,j,o,d) =l= capa(i,j);
 602   
