1272   
1273   
1274  Scalars tau, sigma, a_nom, a_max, M, n_airlines;
1275  tau = 0.85;
1276  sigma = 0.3;
1277  a_nom = 171;
1278  a_max = 1e7;
1279  M = 1e5;
1280  n_airlines = 5;
1281   
1282  Scalar n; n = card(i);
1283   
1284  Scalar epsi; epsi = 1e-3;
1285   
1286  Scalar lam /
INCLUDE    /home/lcadarso/TFM/HubSpokeNetworkDesign/4node_spain/export_txt/lam.txt
1288  4
1289  /;
1290   
1291   
1292  Scalar budget /
INCLUDE    /home/lcadarso/TFM/HubSpokeNetworkDesign/4node_spain/export_txt/budget.txt
1294  30000.0
1295  /;
1296   
1297  Scalar nom_bud
1298  /
INCLUDE    /home/lcadarso/TFM/HubSpokeNetworkDesign/4node_spain/export_txt/budget.txt
1300  30000.0
1301  /;
1302   
1303  Scalar logit_coef; logit_coef = 0.02;
1304   
1305   
1306   
1307  display travel_time,link_cost,link_capacity_slope,prices,candidates,station_cost,station_capacity_slope,a_max,demand;
1308   
1309   
1310  * ---------- Variables ----------
1311  Variables
1312      obj, op_obj, pax_obj, xlen(o,d), budvar
1313  ;
1314   
1315  Positive Variables
1316      s(i), sh(i), a(i,j), f(o,d), fext(o,d), zij(i,j,o,d),
1317      delta(seg,o,d), ghat(o,d)
1318  ;
1319   
1320  Binary Variables
1321      s_bin(i),
1322      sh_bin(i),
1323      a_bin(i,i),
1324      z(i,i),
1325      fij(i,i,i,i),
1326      alfaseg(seg,o,d)
1327  ;
1328   
1329   
1330  * Cotas superiores
1331  f.up(i,j)       = 1;
1332  f.lo(i,j)       = 0;
1333  fext.up(i,j)    = 1;
1334  fext.lo(i,j)    = 0;
1335  zij.up(i,j,o,d) = 1;
1336  zij.lo(i,j,o,d) = 0;
1337   
1338  * ---------- Ecuaciones ----------
1339  Equations
1340      def_bud, def_op_obj, def_pax_obj, def_obj,
1341      bigM_s, bigM_sh, bigM_a, relssh, bud_avail,
1342      link_cap, station_cap, hub_connect_cap, hub_direct_cap,
1343      tot_links, link_sym,
1344      fij_od_flow, fij_do_flow, fij_trans
1345      diag_zero_fo, fij_zero_diag, fij_zero_oo, fij_zero_dd
1346      split_fd, f_leq_Mz
1347      cand_zero
1348      zij_bigM_lb, zij_leq_f, zij_leq_Mfij
1349      def_xlen, alfaseg_sum, delta_bound,delta_bound_last, xlen_interp, slice_bound, ghat_interp, f_leq_ghat
1350  ;
1351   
1352   
1353  def_bud.. budvar =e= sum(i, station_capacity_slope(i)*(s(i)+sh(i)))
1354           + sum(i,
1355                          station_cost(i)*s_bin(i))
1356           + lam*sum(i,
1357                          hub_cost(i)*sh_bin(i));
1358   
1359  * ---------- Objetivo ----------
1360  def_op_obj..
1361      op_obj =e=  sum((i,j), op_link_cost(i,j) * a(i,j));
1362   
1363  def_pax_obj..
1364      pax_obj =e= - sum((o,d), prices(o,d) * demand(o,d) * f(o,d));
1365   
1366  def_obj..
1367      obj =e=  pax_obj + op_obj + 1e-4*sum(i, (1.0001*s(i)+sh(i)+s_bin(i)+sh_bin(i)));
1368   
1369   
1370  * ---------- Restricciones de infraestructura ----------
1371  *sprim_link(i)..          s_prim(i)   =e= s(i) + delta_s(i);
1372  *aprim_link(i,j)..        a_prim(i,j) =e= a(i,j) + delta_a(i,j);
1373   
1374  bigM_s(i)..              s(i)   =l= M * s_bin(i);
1375  bigM_sh(i)..             sh(i)  =l= M * sh_bin(i);
1376  bigM_a(i,j)..            a(i,j) =l= M * a_bin(i,j);
1377  relssh(i)..              sh_bin(i) =l= s_bin(i);
1378   
1379  bud_avail..
1380      budvar =l= budget;
1381   
1382  link_cap(i,j)..
1383       sum((o,d), zij(i,j,o,d) * demand(o,d)) =l= a(i,j) * a_nom * tau;
1384   
1385  station_cap(i)..   sigma * (sum(j, a(j,i)) + sum(j, a(i,j))) =l= s(i) + sh(i);
1386   
1387  hub_connect_cap(i).. sigma * (sum( (o,d,j)$(ord(o)<>ord(i)),
1388      demand(o,d) * zij(i,j,o,d) / (a_nom * tau))  + sum( (o,d,j)$(ord(d)<>ord(i)),
1389      demand(o,d) * zij(j,i,o,d) / (a_nom * tau))) =l= sh(i);
1390   
1391  hub_direct_cap(o,d).. sigma * demand(o,d) * zij(o,d,o,d) / (a_nom * tau) =l= sh(o) + sh(d);
1392   
1393  tot_links.. sum((i,j), a(i,j)) =l= a_max;
1394   
1395  link_sym(i,j).. a(i,j) =e= a(j,i);
1396   
1397  * ---------- Restricciones de flujo ----------
1398  fij_od_flow(o,d)$(ord(o)<>ord(d))..
1399      sum(j$(ord(j)<>ord(o)), fij(o,j,o,d))
1400    - sum(i$(ord(i)<>ord(o)), fij(i,o,o,d))
1401    =e= z(o,d);
1402   
1403  fij_do_flow(o,d)$(ord(o)<>ord(d))..
1404      sum(j$(ord(j)<>ord(d)), fij(d,j,o,d))
1405    - sum(i$(ord(i)<>ord(d)), fij(i,d,o,d))
1406    =e= -z(o,d);
1407   
1408  fij_trans(i,o,d)$(ord(i)<>ord(o) and ord(i)<>ord(d))..
1409      sum(j$(ord(j)<>ord(i)), fij(i,j,o,d))
1410    - sum(ii$(ord(ii)<>ord(i)), fij(ii,i,o,d))
1411    =e= 0;
1412   
1413  diag_zero_fo(o)..            f(o,o) + fext(o,o) =e= 0;
1414  fij_zero_diag(i,o,d)..       fij(i,i,o,d) =e= 0;
1415  fij_zero_oo(o,i,d)..         fij(i,o,o,d) =e= 0;
1416  fij_zero_dd(d,i,o)..         fij(d,i,o,d) =e= 0;
1417   
1418  split_fd(o,d)$(ord(o)<>ord(d))..  f(o,d) + fext(o,d) =e= 1;
1419   
1420  f_leq_Mz(o,d)$(ord(o)<>ord(d))..  f(o,d) =l=  z(o,d);
1421   
1422  cand_zero(i,j)$(candidates(i,j)=0)..  a(i,j) =e= 0;
1423   
1424  zij_bigM_lb(i,j,o,d)..  zij(i,j,o,d) =g= f(o,d) - (1 - fij(i,j,o,d));
1425  zij_leq_f(i,j,o,d)..    zij(i,j,o,d) =l= f(o,d);
1426  zij_leq_Mfij(i,j,o,d).. zij(i,j,o,d) =l= fij(i,j,o,d);
1427   
1428  * ---------- PWL con convex combination + binarios ----------
1429  def_xlen(o,d)$(ord(o)<>ord(d))..
1430      xlen(o,d) =e= sum((i,j), fij(i,j,o,d) * logit_coef*(-travel_time(i,j))) + z(o,d)*logit_coef*(-prices(o,d));
1431   
1432  alfaseg_sum(o,d)$(ord(o)<>ord(d)).. sum(seg,alfaseg(seg,o,d)) =e= 1;
1433   
1434  delta_bound(seg,o,d)$((ord(o)<>ord(d)) and (ord(seg) lt card(seg))).. delta(seg,o,d) =l= alfaseg(seg,o,d)*(b(seg+1,o,d)-b(seg,o,d));
1435   
1436  delta_bound_last(seg,o,d)$(ord(seg)=card(seg))..  delta(seg,o,d) =l= alfaseg(seg,o,d)*(-b(seg,o,d));
1437   
1438  xlen_interp(o,d)$(ord(o)<>ord(d)).. xlen(o,d) =e= sum(seg,alfaseg(seg,o,d)*b(seg,o,d) + delta(seg,o,d));
1439   
1440  slice_bound(seg,o,d)$((ord(seg) lt card(seg)) and (ord(o)<>ord(d)) ).. b(seg,o,d) + delta(seg,o,d) =l= b(seg+1,o,d);
1441   
1442  ghat_interp(o,d)$(ord(o)<>ord(d)).. ghat(o,d) =e= sum(seg,alfaseg(seg,o,d)*bord(seg,o,d) + mreg(seg,o,d)*delta(seg,o,d));
1443   
1444  f_leq_ghat(o,d)$(ord(o)<>ord(d))..     f(o,d) =l= ghat(o,d);
1445   
1446   
1447  * ---------- Modelo y resolución ----------
1448  Model netdesign /
1449      def_bud,
1450      def_op_obj,
1451      def_pax_obj,
1452      def_obj,
1453      bigM_s,
1454      bigM_sh,
1455      bigM_a,
1456      relssh,
1457      bud_avail,
1458      link_cap,
1459      station_cap,
1460      hub_connect_cap, hub_direct_cap,
1461      tot_links,
1462      link_sym,
1463      fij_od_flow, fij_do_flow, fij_trans
1464      diag_zero_fo, fij_zero_diag, fij_zero_oo, fij_zero_dd
1465      split_fd, f_leq_Mz
1466      cand_zero
1467      zij_bigM_lb,
1468      zij_leq_f, zij_leq_Mfij
1469      def_xlen
1470      alfaseg_sum
1471      delta_bound
1472      delta_bound_last
1473      slice_bound
1474      xlen_interp
1475      ghat_interp,
1476      f_leq_ghat
1477  /;
1478   
1479   
1480   
1481   
1482  option threads = 60;
1483  option mip     = cplex;
1484   
1485  option reslim = 600;
1486   
1487  Parameter mipgap;
1488   
1489   
1490  Solve netdesign using mip minimizing obj;
1491   
1492  * ---------- Salidas básicas ----------
1493  *Display f.l, fext.l, fij.l, xlen.l, ghat.l,
1494  *        obj.l, op_obj.l, pax_obj.l,
1495  *        s.l, s_bin.l, a.l, a_bin.l, z.l, b;
1496   
1497  mipgap = abs(netdesign.objval - netdesign.objest) / (1e-9 + abs(netdesign.objval));
1498   
1499  Parameter solverTime;
1500   
1501  solverTime = netdesign.resusd;
1502   
1503  Display b,budget,netdesign.objval, netdesign.objest, mipgap;
1504   
1505   
