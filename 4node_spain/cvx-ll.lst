 353  display travel_time,link_cost,link_capacity_slope,prices,candidates,station_cost,station_capacity_slope,a_max, iter, niters, demand;
 354   
 355   
 356  *---------------------*
 357  * Variables           *
 358  *---------------------*
 359   
 360   
 361  Nonnegative Variable
 362      s(i),       sh(i),
 363      a(i,j),
 364      f(o,d),      fext(o,d), f_aux(o,d), fext_aux(o,d),
 365      fij(i,j,o,d), exceed
 366      ;
 367   
 368  Variable bud, op, ut, pax, obj, ft(o,d),ftext(o,d),fr(o,d),frext(o,d),fy(o,d),fyext(o,d), t(i);
 369   
 370   
 371   
 372  *---------------------*
 373  * Ecuaciones          *
 374  *---------------------*
 375  Equation
 376      bud_def      "definición de bud_obj"
 377      op_def       "definición de op_obj"
 378      pax_def      "definición de pax_obj"
 379      obj_def      "objetivo total"
 380      utility_def
 381   
 382      def_f_aux
 383      def_f_aux2
 384      def_fext_aux
 385      def_fext_aux2
 386   
 387      link_sym(i,j)
 388      prim_s_def(i)
 389      prim_a_def(i,j)
 390   
 391      link_cap(i,j)
 392      station_cap(i)
 393      hub_connect_cap(i)
 394      hub_direct_cap(o,d)
 395   
 396      tot_links
 397      link_flow_to_f(o,d)
 398   
 399      profitability(o,d)
 400   
 401      bud_avail
 402      bud_final
 403   
 404      flow_start(o,d)     "conservación en origen o para cada destino d != o"
 405      flow_end(o,d)       "conservación en destino d para cada origen o != d"
 406      flow_mid(i,o,d)     "conservación en nodos intermedios i != o,d"
 407   
 408      zero_diag_od(o)
 409      zero_fij_self(i,o,d)
 410      zero_fij_origin(o,i,d)
 411      zero_fij_dest(d,i,o)
 412      zero_diag_odext
 413   
 414      split_choice(o,d)
 415      candidates_zero(i,j)
 416   
 417      fix_s_at_zero(i)
 418      fix_sh_at_zero(i)
 419   
 420      expconef(o,d)
 421      exponefext(o,d)
 422      epigraphf(o,d)
 423      epigraphfext(o,d)
 424   
 425      def_deltasaux(i)
 426   
 427      def_deltaaaux(i,j)
 428   
 429      powercones(i)
 430      powerconea(i,j)
 431   
 432      cuad_cone(i)
 433  *rescap
 434  ;
 435   
 436  *---------------------*
 437  * Definición objetivo *
 438  *---------------------*
 439   
 440  * Presupuesto (bud): costes lineales + (si iter<niters) costes fijos aproximados
 441  bud_def..
 442      bud =e= sum(i, station_capacity_slope(i)*(s(i) + sh(i)))
 443           + sum(i,
 444                          station_cost(i)*(s(i)+sh(i))/((s_prev(i)+sh_prev(i))+epsi))
 445           + sum(i,
 446                          lam*hub_cost(i)*sh(i)/(sh_prev(i)+epsi)) ;
 447   
 448   
 449   
 450   
 451   
 452  * Operación (op): coste lineal de operar enlaces
 453  op_def..
 454      op =e= 1e-3*sum((i,j), op_link_cost(i,j) * a(i,j));
 455   
 456  * Pasajeros (pax): tiempos/precios en ruta y alternativas + entropías
 457  pax_def..
 458      pax =e= 1e-2*(
 459   
 460      + sum((o,d)$(ord(o) ne ord(d)),alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) * (ft(o,d)))
 461  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
 462   
 463     + sum((o,d), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *(ftext(o,d)
 464     - fext_aux(o,d)*log(n_airlines))) );
 465   
 466   
 467  utility_def..
 468      ut =e= 1e-2*(
 469        sum((o,d)$(ord(o) ne ord(d)),
 470              alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *
 471             ( logit_coef*prices(o,d)*f(o,d) + sum((i,j), (travel_time(i,j))*fij(i,j,o,d)*logit_coef)))
 472   
 473      - sum((o,d)$(ord(o) ne ord(d)), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d)
 474            * alt_utility(o,d)*fext(o,d)) );
 475   
 476   
 477   
 478  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
 479   
 480  *    + 1e-3*sum((o,d), demand(o,d)
 481  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
 482   
 483  *   + 1e-3*sum((o,d), demand(o,d)
 484  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
 485  *    +1e-3*sum(i,deltast(i))
 486  *  + 1e-3*sum(i,
 487  *         1/(congestion_coefs_stations(i)*deltas(i) + epsi))
 488  *    +1e-3*sum((i,j),deltaat(i,j))
 489  *    + 1e-3*sum((i,j),
 490  *          1/(congestion_coefs_links(i,j)*deltaa(i,j) + epsi))
 491  ;
 492   
 493  * Objetivo total
 494  obj_def..
 495      obj =e= pax + ut + 1e-6*bud$(iter < niters) + 1e6*exceed + op;
 496   
 497  *+ op + ut + 1e6*exceed + 1e-6*bud$(iter < niters);
 498   
 499   
 500   
 501  *---------------------*
 502  * Restricciones       *
 503  *---------------------*
 504   
 505   
 506  bud_avail..
 507      bud$(iter < niters) =l= budget;
 508   
 509  bud_final..
 510      ( sum(i, station_capacity_slope(i)*(s(i) + sh(i)))   + sum(i$((s_prev(i) > 0.01) or (sh_prev(i) > 0.01)), station_cost(i))
 511    + sum(i$(sh_prev(i) > 0.01), lam*hub_cost(i)))$(iter = niters)
 512      =l=
 513      budget
 514  ;
 515   
 516   
 517  profitability(o,d).. demand(o,d)*prices(o,d)*f(o,d) =g= sum((i,j),demand(o,d)*fij(i,j,o,d)*op_link_cost(i,j)/(a_nom*tau));
 518   
 519  * Simetría de a_prim
 520  link_sym(i,j)$(ord(i) ne ord(j))..  a(i,j) =e= a(j,i);
 521   
 522  * Capacidad de enlace: sum_{o,d} fij(i,j,o,d)*demand(o,d) <= tau*a(i,j)*a_nom
 523  link_cap(i,j)..
 524      sum((o,d), fij(i,j,o,d)*demand(o,d)) =l= a(i,j)*a_nom*tau;
 525   
 526   
 527   
 528  station_cap(i)..   sigma * (sum(j, a(j,i)) + sum(j, a(i,j))) =l= s(i) + sh(i);
 529   
 530   
 531  hub_connect_cap(i).. sigma * (sum( (o,d,j)$(ord(o)<>ord(i)),
 532      demand(o,d) * fij(i,j,o,d) / (a_nom * tau))  + sum( (o,d,j)$(ord(d)<>ord(i)),
 533      demand(o,d) * fij(j,i,o,d) / (a_nom * tau))) =l= sh(i);
 534   
 535   
 536  hub_direct_cap(o,d).. sigma * demand(o,d) * fij(o,d,o,d) / (a_nom * tau) =l= sh(o) + sh(d);
 537   
 538   
 539  * Límite total de links construidos/operativos
 540  tot_links..
 541      sum((i,j), a(i,j)) =l= a_max;
 542   
 543  * Relación f con flujos saliendo del origen
 544  link_flow_to_f(o,d)..
 545      sum(j, fij(o,j,o,d)) =e= f(o,d);
 546   
 547  * Conservación en nodos de origen (para k!=o): sum_out - sum_in = 1 - fext(o,k)
 548  flow_start(o,d)$(ord(o) ne ord(d))..
 549      ( sum(j, fij(o,j,o,d)) - sum(i, fij(i,o,o,d)) ) =e= 1 - fext(o,d);
 550   
 551  * Conservación en nodos destino (para k!=d): sum_out - sum_in = -1 + fext(k,d)
 552  flow_end(o,d)$(ord(o) ne ord(d))..
 553      ( sum(j, fij(d,j,o,d)) - sum(i, fij(i,d,o,d)) ) =e= -1 + fext(o,d);
 554   
 555  * Conservación en nodos intermedios i != o,d: sum_out - sum_in = 0
 556  flow_mid(i,o,d)$( (ord(o) ne ord(i)) and (ord(i) ne ord(d)) )..
 557      ( sum(j, fij(i,j,o,d)) - sum(j, fij(j,i,o,d)) ) =e= 0;
 558   
 559  * Zeros en diagonal y bloques prohibidos (replican fij(:,o,o,:) == 0, etc.)
 560  zero_diag_od(o)..           f(o,o)    =l= epsi;
 561  * fext(o,o)=0:
 562  zero_diag_odext(o)..           fext(o,o)    =l= epsi;
 563   
 564  * fij(i,i,*,*) = 0
 565  zero_fij_self(i,o,d)..      fij(i,i,o,d) =l= epsi;
 566   
 567  * fij(:,o,o,:) = 0  -> i cualquiera, j=o, o=o, d cualquiera
 568  zero_fij_origin(o,i,d)..    fij(i,o,o,d) =l= epsi;
 569   
 570  * fij(d,:,:,d) = 0  -> i=d, j cualquiera, o cualquiera, d=d
 571  zero_fij_dest(d,i,o)..      fij(d,i,o,d) =l= epsi;
 572   
 573  * Split: para o!=d, f + fext = 1
 574  split_choice(o,d)$(ord(o) ne ord(d))..
 575      f(o,d) + fext(o,d) =e= 1;
 576   
 577  * Enlaces no candidatesidatos forzados a 0: a_prim(i,j)=0 si ~(i,j) en candidates
 578  candidates_zero(i,j)$(not candidates(i,j))..
 579      a(i,j) =e= 0;
 580   
 581  * Fijaciones en la iteración final si previos pequeños (replica iter==niters … <=0.1)
 582  fix_s_at_zero(i)$( (s_prev(i) <= 0.01) and (iter = niters) )..
 583      s(i) =l= epsi;
 584   
 585  fix_sh_at_zero(i)$( (sh_prev(i) <= 0.01) and (iter = niters) )..
 586      sh(i) =l= epsi;
 587   
 588   
 589  def_f_aux(o,d).. f_aux(o,d) =l= f(o,d) + epsi_f;
 590  def_f_aux2(o,d).. f_aux(o,d) =g= f(o,d) - epsi_f;
 591   
 592   
 593   
 594  def_fext_aux(o,d).. fext_aux(o,d) =l= fext(o,d) + epsi_f;
 595  def_fext_aux2(o,d).. fext_aux(o,d) =g= fext(o,d) - epsi_f;
 596   
 597   
