 431      powerconea(i,j)
 432   
 433      cuad_cone(i)
 434  *rescap
 435  ;
 436   
 437  *---------------------*
 438  * Definición objetivo *
 439  *---------------------*
 440   
 441  * Presupuesto (bud): costes lineales + (si iter<niters) costes fijos aproximados
 442  bud_def..
 443      bud =e= sum(i, station_capacity_slope(i)*(s(i) + sh(i)))
 444           + sum(i,
 445                          station_cost(i)*(s(i)+sh(i))/((s_prev(i)+sh_prev(i))+epsi))
 446           + sum(i,
 447                          lam*hub_cost(i)*sh(i)/(sh_prev(i)+epsi)) ;
 448   
 449   
 450   
 451   
 452   
 453  * Operación (op): coste lineal de operar enlaces
 454  op_def..
 455      op =e= 1e-3*sum((i,j), op_link_cost(i,j) * a(i,j));
 456   
 457  * Pasajeros (pax): tiempos/precios en ruta y alternativas + entropías
 458  pax_def..
 459      pax =e= 1e-2*(
 460   
 461      + sum((o,d)$(ord(o) ne ord(d)),alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) * (ft(o,d)))
 462  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
 463   
 464     + sum((o,d), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *(ftext(o,d)
 465     - fext_aux(o,d)*log(n_airlines))) );
 466   
 467   
 468  utility_def..
 469      ut =e= 1e-2*(
 470        sum((o,d)$(ord(o) ne ord(d)),
 471              alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *
 472             ( logit_coef*prices(o,d)*f(o,d) + sum((i,j), (travel_time(i,j))*fij(i,j,o,d)*logit_coef)))
 473   
 474      - sum((o,d)$(ord(o) ne ord(d)), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d)
 475            * alt_utility(o,d)*fext(o,d)) );
 476   
 477   
 478   
 479  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
 480   
 481  *    + 1e-3*sum((o,d), demand(o,d)
 482  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
 483   
 484  *   + 1e-3*sum((o,d), demand(o,d)
 485  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
 486  *    +1e-3*sum(i,deltast(i))
 487  *  + 1e-3*sum(i,
 488  *         1/(congestion_coefs_stations(i)*deltas(i) + epsi))
 489  *    +1e-3*sum((i,j),deltaat(i,j))
 490  *    + 1e-3*sum((i,j),
 491  *          1/(congestion_coefs_links(i,j)*deltaa(i,j) + epsi))
 492  ;
 493   
 494  * Objetivo total
 495  obj_def..
 496      obj =e= pax + ut + 1e-6*bud$(iter < niters) + 1e6*exceed + op;
 497   
 498  *+ op + ut + 1e6*exceed + 1e-6*bud$(iter < niters);
 499   
 500   
 501   
 502  *---------------------*
 503  * Restricciones       *
 504  *---------------------*
 505   
 506   
 507  bud_avail..
 508      bud$(iter < niters) =l= budget;
 509   
 510  bud_final..
 511      ( sum(i, station_capacity_slope(i)*(s(i) + sh(i)))   + sum(i$((s_prev(i) > 0.01) or (sh_prev(i) > 0.01)), station_cost(i))
 512    + sum(i$(sh_prev(i) > 0.01), lam*hub_cost(i)))$(iter = niters)
 513      =l=
 514      budget
 515  ;
 516   
 517   
 518  profitability(o,d).. demand(o,d)*prices(o,d)*f(o,d) =g= sum((i,j),demand(o,d)*fij(i,j,o,d)*op_link_cost(i,j)/(a_nom*tau));
 519   
 520  * Simetría de a_prim
 521  link_sym(i,j)$(ord(i) ne ord(j))..  a(i,j) =e= a(j,i);
 522   
 523  * Capacidad de enlace: sum_{o,d} fij(i,j,o,d)*demand(o,d) <= tau*a(i,j)*a_nom
 524  link_cap(i,j)..
 525      sum((o,d), fij(i,j,o,d)*demand(o,d)) =l= a(i,j)*a_nom*tau;
 526   
 527   
 528   
 529  station_cap(i)..   sigma * (sum(j, a(j,i)) + sum(j, a(i,j))) =l= s(i) + sh(i);
 530   
 531   
 532  hub_connect_cap(i).. sigma * (sum( (o,d,j)$(ord(o)<>ord(i)),
 533      demand(o,d) * fij(i,j,o,d) / (a_nom * tau))  + sum( (o,d,j)$(ord(d)<>ord(i)),
 534      demand(o,d) * fij(j,i,o,d) / (a_nom * tau))) =l= sh(i);
 535   
 536   
 537  hub_direct_cap(o,d).. sigma * demand(o,d) * fij(o,d,o,d) / (a_nom * tau) =l= sh(o) + sh(d);
 538   
 539   
 540  * Límite total de links construidos/operativos
 541  tot_links..
 542      sum((i,j), a(i,j)) =l= a_max;
 543   
 544  * Relación f con flujos saliendo del origen
 545  link_flow_to_f(o,d)..
 546      sum(j, fij(o,j,o,d)) =e= f(o,d);
 547   
 548  * Conservación en nodos de origen (para k!=o): sum_out - sum_in = 1 - fext(o,k)
 549  flow_start(o,d)$(ord(o) ne ord(d))..
 550      ( sum(j, fij(o,j,o,d)) - sum(i, fij(i,o,o,d)) ) =e= 1 - fext(o,d);
 551   
 552  * Conservación en nodos destino (para k!=d): sum_out - sum_in = -1 + fext(k,d)
 553  flow_end(o,d)$(ord(o) ne ord(d))..
 554      ( sum(j, fij(d,j,o,d)) - sum(i, fij(i,d,o,d)) ) =e= -1 + fext(o,d);
 555   
 556  * Conservación en nodos intermedios i != o,d: sum_out - sum_in = 0
 557  flow_mid(i,o,d)$( (ord(o) ne ord(i)) and (ord(i) ne ord(d)) )..
 558      ( sum(j, fij(i,j,o,d)) - sum(j, fij(j,i,o,d)) ) =e= 0;
 559   
 560  * Zeros en diagonal y bloques prohibidos (replican fij(:,o,o,:) == 0, etc.)
 561  zero_diag_od(o)..           f(o,o)    =l= epsi;
 562  * fext(o,o)=0:
 563  zero_diag_odext(o)..           fext(o,o)    =l= epsi;
 564   
 565  * fij(i,i,*,*) = 0
 566  zero_fij_self(i,o,d)..      fij(i,i,o,d) =l= epsi;
 567   
 568  * fij(:,o,o,:) = 0  -> i cualquiera, j=o, o=o, d cualquiera
 569  zero_fij_origin(o,i,d)..    fij(i,o,o,d) =l= epsi;
 570   
 571  * fij(d,:,:,d) = 0  -> i=d, j cualquiera, o cualquiera, d=d
 572  zero_fij_dest(d,i,o)..      fij(d,i,o,d) =l= epsi;
 573   
 574  * Split: para o!=d, f + fext = 1
 575  split_choice(o,d)$(ord(o) ne ord(d))..
 576      f(o,d) + fext(o,d) =e= 1;
 577   
 578  * Enlaces no candidatesidatos forzados a 0: a_prim(i,j)=0 si ~(i,j) en candidates
 579  candidates_zero(i,j)$(not candidates(i,j))..
 580      a(i,j) =e= 0;
