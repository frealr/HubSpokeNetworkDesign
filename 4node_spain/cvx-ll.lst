 599   
 600   
 601  exponefext(o,d)..  fyext(o,d) =g= fext_aux(o,d)*exp(frext(o,d)/fext_aux(o,d));
 602   
 603  epigraphf(o,d)..  ft(o,d) =g= -fr(o,d)-f_aux(o,d);
 604   
 605  epigraphfext(o,d)..  ftext(o,d) =g= -frext(o,d)-fext_aux(o,d);
 606   
 607  cuad_cone(i).. t(i) =g= sqr(sh(i) - s(i));
 608   
 609  *rescap(i,j,o,d).. fij(i,j,o,d) =l= capa(i,j);
