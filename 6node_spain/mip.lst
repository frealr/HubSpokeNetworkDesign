2681   
2682   
2683  Scalars tau, sigma, a_nom, a_max, M, n_airlines;
2684  tau = 0.85;
2685  sigma = 0.3;
2686  a_nom = 171;
2687  a_max = 1e7;
2688  M = 1e5;
2689  n_airlines = 5;
2690   
2691  Scalar n; n = card(i);
2692   
2693  Scalar epsi; epsi = 1e-3;
2694   
2695  Scalar lam /
INCLUDE    /home/lcadarso/TFM/HubSpokeNetworkDesign/6node_spain/export_txt/lam.txt
2697  4
2698  /;
2699   
2700  Scalar alfa /
INCLUDE    /home/lcadarso/TFM/HubSpokeNetworkDesign/6node_spain/export_txt/alfa.txt
2702  0.5
2703  /;
2704   
2705   
2706  Scalar dm_pax /
INCLUDE    /home/lcadarso/TFM/HubSpokeNetworkDesign/6node_spain/export_txt/dm_pax.txt
2708  1.000000e-02
2709  /;
2710   
2711  Scalar dm_op /
INCLUDE    /home/lcadarso/TFM/HubSpokeNetworkDesign/6node_spain/export_txt/dm_op.txt
2713  8.000000e-03
2714  /;
2715   
2716  Scalar budget /
INCLUDE    /home/lcadarso/TFM/HubSpokeNetworkDesign/6node_spain/export_txt/budget.txt
2718  30000
2719  /;
2720   
2721  Scalar nom_bud
2722  /
INCLUDE    /home/lcadarso/TFM/HubSpokeNetworkDesign/6node_spain/export_txt/budget.txt
2724  30000
2725  /;
2726   
2727  Scalar logit_coef; logit_coef = 0.02;
2728   
2729   
2730   
2731  display travel_time,link_cost,link_capacity_slope,prices,candidates,station_cost,station_capacity_slope,a_max,demand;
2732   
2733  * ---------- Variables ----------
2734  Variables
2735      obj, op_obj, pax_obj, xlen(o,d), budvar
2736  ;
2737   
2738  Positive Variables
2739      s(i), sh(i), a(i,j), f(o,d), fext(o,d), zij(i,j,o,d),
2740      delta(seg,o,d), ghat(o,d)
2741  ;
2742   
2743  Binary Variables
2744      s_bin(i),
2745      sh_bin(i),
2746      a_bin(i,i),
2747      z(i,i),
2748      fij(i,i,i,i),
2749      alfaseg(seg,o,d)
2750  ;
2751   
2752   
2753  * Cotas superiores
2754  f.up(i,j)       = 1;
2755  f.lo(i,j)       = 0;
2756  fext.up(i,j)    = 1;
2757  fext.lo(i,j)    = 0;
2758  zij.up(i,j,o,d) = 1;
2759  zij.lo(i,j,o,d) = 0;
2760   
2761  * ---------- Ecuaciones ----------
2762  Equations
2763      def_bud, def_op_obj, def_pax_obj, def_obj,
2764      bigM_s, bigM_sh, bigM_a, relssh, bud_avail,
2765      link_cap, station_cap, hub_connect_cap, hub_direct_cap,
2766      tot_links, link_sym,
2767      fij_od_flow, fij_do_flow, fij_trans
2768      diag_zero_fo, fij_zero_diag, fij_zero_oo, fij_zero_dd
2769      split_fd, f_leq_Mz
2770      cand_zero
2771      zij_bigM_lb, zij_leq_f, zij_leq_Mfij
2772      def_xlen, alfaseg_sum, delta_bound,delta_bound_last, xlen_interp, slice_bound, ghat_interp, f_leq_ghat
2773  ;
2774   
2775   
2776  def_bud.. budvar =e= sum(i, station_capacity_slope(i)*(s(i)+sh(i)))
2777           + sum(i,
2778                          station_cost(i)*s_bin(i))
2779           + lam*sum(i,
2780                          hub_cost(i)*sh_bin(i));
2781   
2782  * ---------- Objetivo ----------
2783  def_op_obj..
2784      op_obj =e=  sum((i,j), op_link_cost(i,j) * a(i,j));
2785   
2786  def_pax_obj..
2787      pax_obj =e= - sum((o,d), prices(o,d) * demand(o,d) * f(o,d));
2788   
2789  def_obj..
2790      obj =e=  pax_obj + op_obj + 1e-4*sum(i, (1.0001*s(i)+sh(i)+s_bin(i)+sh_bin(i)));
2791   
2792   
2793  * ---------- Restricciones de infraestructura ----------
2794  *sprim_link(i)..          s_prim(i)   =e= s(i) + delta_s(i);
2795  *aprim_link(i,j)..        a_prim(i,j) =e= a(i,j) + delta_a(i,j);
2796   
2797  bigM_s(i)..              s(i)   =l= M * s_bin(i);
2798  bigM_sh(i)..             sh(i)  =l= M * sh_bin(i);
2799  bigM_a(i,j)..            a(i,j) =l= M * a_bin(i,j);
2800  relssh(i)..              sh_bin(i) =l= s_bin(i);
2801   
2802  bud_avail..
2803      budvar =l= budget;
2804   
2805  link_cap(i,j)..
2806       sum((o,d), zij(i,j,o,d) * demand(o,d)) =l= a(i,j) * a_nom * tau;
2807   
2808  station_cap(i)..   sigma * (sum(j, a(j,i)) + sum(j, a(i,j))) =l= s(i) + sh(i);
2809   
2810  hub_connect_cap(i).. sigma * (sum( (o,d,j)$(ord(o)<>ord(i)),
2811      demand(o,d) * zij(i,j,o,d) / (a_nom * tau))  + sum( (o,d,j)$(ord(d)<>ord(i)),
2812      demand(o,d) * zij(j,i,o,d) / (a_nom * tau))) =l= sh(i);
2813   
2814  hub_direct_cap(o,d).. sigma * demand(o,d) * zij(o,d,o,d) / (a_nom * tau) =l= sh(o) + sh(d);
2815   
2816  tot_links.. sum((i,j), a(i,j)) =l= a_max;
2817   
2818  link_sym(i,j).. a(i,j) =e= a(j,i);
2819   
2820  * ---------- Restricciones de flujo ----------
2821  fij_od_flow(o,d)$(ord(o)<>ord(d))..
2822      sum(j$(ord(j)<>ord(o)), fij(o,j,o,d))
2823    - sum(i$(ord(i)<>ord(o)), fij(i,o,o,d))
2824    =e= z(o,d);
2825   
2826  fij_do_flow(o,d)$(ord(o)<>ord(d))..
2827      sum(j$(ord(j)<>ord(d)), fij(d,j,o,d))
2828    - sum(i$(ord(i)<>ord(d)), fij(i,d,o,d))
2829    =e= -z(o,d);
2830   
2831  fij_trans(i,o,d)$(ord(i)<>ord(o) and ord(i)<>ord(d))..
2832      sum(j$(ord(j)<>ord(i)), fij(i,j,o,d))
2833    - sum(ii$(ord(ii)<>ord(i)), fij(ii,i,o,d))
2834    =e= 0;
2835   
2836  diag_zero_fo(o)..            f(o,o) + fext(o,o) =e= 0;
2837  fij_zero_diag(i,o,d)..       fij(i,i,o,d) =e= 0;
2838  fij_zero_oo(o,i,d)..         fij(i,o,o,d) =e= 0;
2839  fij_zero_dd(d,i,o)..         fij(d,i,o,d) =e= 0;
2840   
2841  split_fd(o,d)$(ord(o)<>ord(d))..  f(o,d) + fext(o,d) =e= 1;
2842   
2843  f_leq_Mz(o,d)$(ord(o)<>ord(d))..  f(o,d) =l=  z(o,d);
2844   
2845  cand_zero(i,j)$(candidates(i,j)=0)..  a(i,j) =e= 0;
2846   
2847  zij_bigM_lb(i,j,o,d)..  zij(i,j,o,d) =g= f(o,d) - (1 - fij(i,j,o,d));
2848  zij_leq_f(i,j,o,d)..    zij(i,j,o,d) =l= f(o,d);
2849  zij_leq_Mfij(i,j,o,d).. zij(i,j,o,d) =l= fij(i,j,o,d);
2850   
2851  * ---------- PWL con convex combination + binarios ----------
2852  def_xlen(o,d)$(ord(o)<>ord(d))..
2853      xlen(o,d) =e= sum((i,j), fij(i,j,o,d) * logit_coef*(-travel_time(i,j))) + z(o,d)*logit_coef*(-prices(o,d));
2854   
2855  alfaseg_sum(o,d)$(ord(o)<>ord(d)).. sum(seg,alfaseg(seg,o,d)) =e= 1;
2856   
2857  delta_bound(seg,o,d)$((ord(o)<>ord(d)) and (ord(seg) lt card(seg))).. delta(seg,o,d) =l= alfaseg(seg,o,d)*(b(seg+1,o,d)-b(seg,o,d));
2858   
2859  delta_bound_last(seg,o,d)$(ord(seg)=card(seg))..  delta(seg,o,d) =l= alfaseg(seg,o,d)*(-b(seg,o,d));
2860   
2861  xlen_interp(o,d)$(ord(o)<>ord(d)).. xlen(o,d) =e= sum(seg,alfaseg(seg,o,d)*b(seg,o,d) + delta(seg,o,d));
2862   
2863  slice_bound(seg,o,d)$((ord(seg) lt card(seg)) and (ord(o)<>ord(d)) ).. b(seg,o,d) + delta(seg,o,d) =l= b(seg+1,o,d);
2864   
2865  ghat_interp(o,d)$(ord(o)<>ord(d)).. ghat(o,d) =e= sum(seg,alfaseg(seg,o,d)*bord(seg,o,d) + mreg(seg,o,d)*delta(seg,o,d));
2866   
2867  f_leq_ghat(o,d)$(ord(o)<>ord(d))..     f(o,d) =l= ghat(o,d);
2868   
2869   
2870  * ---------- Modelo y resolución ----------
2871  Model netdesign /
2872      def_bud,
2873      def_op_obj,
2874      def_pax_obj,
2875      def_obj,
2876      bigM_s,
2877      bigM_sh,
2878      bigM_a,
2879      relssh,
2880      bud_avail,
2881      link_cap,
2882      station_cap,
2883      hub_connect_cap, hub_direct_cap,
2884      tot_links,
2885      link_sym,
2886      fij_od_flow, fij_do_flow, fij_trans
2887      diag_zero_fo, fij_zero_diag, fij_zero_oo, fij_zero_dd
2888      split_fd, f_leq_Mz
2889      cand_zero
2890      zij_bigM_lb,
2891      zij_leq_f, zij_leq_Mfij
2892      def_xlen
2893      alfaseg_sum
2894      delta_bound
2895      delta_bound_last
2896      slice_bound
2897      xlen_interp
2898      ghat_interp,
2899      f_leq_ghat
2900  /;
2901   
2902   
2903   
2904   
2905  option threads = 60;
2906  option mip     = cplex;
2907   
2908  option reslim = 60;
2909   
2910  Parameter mipgap;
2911   
2912   
2913  Solve netdesign using mip minimizing obj;
2914   
2915  * ---------- Salidas básicas ----------
2916  *Display f.l, fext.l, fij.l, xlen.l, ghat.l,
2917  *        obj.l, op_obj.l, pax_obj.l,
2918  *        s.l, s_bin.l, a.l, a_bin.l, z.l, b;
2919   
2920  mipgap = abs(netdesign.objval - netdesign.objest) / (1e-9 + abs(netdesign.objval));
2921   
2922  Parameter solverTime;
2923   
2924  solverTime = netdesign.resusd;
2925   
2926  Display b,budget,netdesign.objval, netdesign.objest, mipgap;
2927   
2928   
2929  Parameter fnew(o,i,j,d);
2930   
2931  fnew(o,i,j,d)=fij.l(i,j,o,d);
2932  execute_unload "resultado.gdx";
2933   
2934   
2935   
