INCLUDE    /home/lcadarso/TFM/HubSpokeNetworkDesign/6node_spain/export_txt/dm_op.txt
4873  8.000000e-03
4874  /;
4875   
4876  Scalar budget /
INCLUDE    /home/lcadarso/TFM/HubSpokeNetworkDesign/6node_spain/export_txt/budget.txt
4878  80000
4879  /;
4880   
4881  Scalar nom_bud
4882  /
INCLUDE    /home/lcadarso/TFM/HubSpokeNetworkDesign/6node_spain/export_txt/budget.txt
4884  80000
4885  /;
4886   
4887  Scalar logit_coef; logit_coef = 0.02;
4888   
4889   
4890   
4891  display travel_time,link_cost,link_capacity_slope,prices,candidates,station_cost,station_capacity_slope,a_max,demand;
4892   
4893  * ---------- Variables ----------
4894  Variables
4895      obj, op_obj, pax_obj, xlen(o,d), budvar
4896  ;
4897   
4898  Positive Variables
4899      s(i), sh(i), a(i,j), f(o,d), fext(o,d), zij(i,j,o,d),
4900      delta(seg,o,d), ghat(o,d)
4901  ;
4902   
4903  Binary Variables
4904      s_bin(i),
4905      sh_bin(i),
4906      a_bin(i,i),
4907      z(i,i),
4908      fij(i,i,i,i),
4909      alfaseg(seg,o,d)
4910  ;
4911   
4912   
4913  * Cotas superiores
4914  f.up(i,j)       = 1;
4915  f.lo(i,j)       = 0;
4916  fext.up(i,j)    = 1;
4917  fext.lo(i,j)    = 0;
4918  zij.up(i,j,o,d) = 1;
4919  zij.lo(i,j,o,d) = 0;
4920   
4921  * ---------- Ecuaciones ----------
4922  Equations
4923      def_bud, def_op_obj, def_pax_obj, def_obj,
4924      bigM_s, bigM_sh, bigM_a, relssh, bud_avail,
4925      link_cap, station_cap, hub_connect_cap, hub_direct_cap,
4926      tot_links, link_sym,
4927      fij_od_flow, fij_do_flow, fij_trans
4928      diag_zero_fo, fij_zero_diag, fij_zero_oo, fij_zero_dd
4929      split_fd, f_leq_Mz
4930      cand_zero
4931      zij_bigM_lb, zij_leq_f, zij_leq_Mfij
4932      def_xlen, alfaseg_sum, delta_bound,delta_bound_last, xlen_interp, slice_bound, ghat_interp, f_leq_ghat
4933  ;
4934   
4935   
4936  def_bud.. budvar =e= sum(i, station_capacity_slope(i)*(s(i)+sh(i)))
4937           + sum(i,
4938                          station_cost(i)*s_bin(i))
4939           + lam*sum(i,
4940                          hub_cost(i)*sh_bin(i));
4941   
4942  * ---------- Objetivo ----------
4943  def_op_obj..
4944      op_obj =e=  sum((i,j), op_link_cost(i,j) * a(i,j));
4945   
4946  def_pax_obj..
4947      pax_obj =e= - sum((o,d), prices(o,d) * demand(o,d) * f(o,d));
4948   
4949  def_obj..
4950      obj =e=  pax_obj + op_obj + 1e-4*sum(i, (1.0001*s(i)+sh(i)+s_bin(i)+sh_bin(i)));
4951   
4952   
4953  * ---------- Restricciones de infraestructura ----------
4954  *sprim_link(i)..          s_prim(i)   =e= s(i) + delta_s(i);
4955  *aprim_link(i,j)..        a_prim(i,j) =e= a(i,j) + delta_a(i,j);
4956   
4957  bigM_s(i)..              s(i)   =l= M * s_bin(i);
4958  bigM_sh(i)..             sh(i)  =l= M * sh_bin(i);
4959  bigM_a(i,j)..            a(i,j) =l= M * a_bin(i,j);
4960  relssh(i)..              sh_bin(i) =l= s_bin(i);
4961   
4962  bud_avail..
4963      budvar =l= budget;
4964   
4965  link_cap(i,j)..
4966       sum((o,d), zij(i,j,o,d) * demand(o,d)) =l= a(i,j) * a_nom * tau;
4967   
4968  station_cap(i)..   sigma * (sum(j, a(j,i)) + sum(j, a(i,j))) =l= s(i) + sh(i);
4969   
4970  hub_connect_cap(i).. sigma * (sum( (o,d,j)$(ord(o)<>ord(i)),
4971      demand(o,d) * zij(i,j,o,d) / (a_nom * tau))  + sum( (o,d,j)$(ord(d)<>ord(i)),
4972      demand(o,d) * zij(j,i,o,d) / (a_nom * tau))) =l= sh(i);
4973   
4974  hub_direct_cap(o,d).. sigma * demand(o,d) * zij(o,d,o,d) / (a_nom * tau) =l= sh(o) + sh(d);
4975   
4976  tot_links.. sum((i,j), a(i,j)) =l= a_max;
4977   
4978  link_sym(i,j).. a(i,j) =e= a(j,i);
4979   
4980  * ---------- Restricciones de flujo ----------
4981  fij_od_flow(o,d)$(ord(o)<>ord(d))..
4982      sum(j$(ord(j)<>ord(o)), fij(o,j,o,d))
4983    - sum(i$(ord(i)<>ord(o)), fij(i,o,o,d))
4984    =e= z(o,d);
4985   
4986  fij_do_flow(o,d)$(ord(o)<>ord(d))..
4987      sum(j$(ord(j)<>ord(d)), fij(d,j,o,d))
4988    - sum(i$(ord(i)<>ord(d)), fij(i,d,o,d))
4989    =e= -z(o,d);
4990   
4991  fij_trans(i,o,d)$(ord(i)<>ord(o) and ord(i)<>ord(d))..
4992      sum(j$(ord(j)<>ord(i)), fij(i,j,o,d))
4993    - sum(ii$(ord(ii)<>ord(i)), fij(ii,i,o,d))
4994    =e= 0;
4995   
4996  diag_zero_fo(o)..            f(o,o) + fext(o,o) =e= 0;
4997  fij_zero_diag(i,o,d)..       fij(i,i,o,d) =e= 0;
4998  fij_zero_oo(o,i,d)..         fij(i,o,o,d) =e= 0;
4999  fij_zero_dd(d,i,o)..         fij(d,i,o,d) =e= 0;
5000   
5001  split_fd(o,d)$(ord(o)<>ord(d))..  f(o,d) + fext(o,d) =e= 1;
5002   
5003  f_leq_Mz(o,d)$(ord(o)<>ord(d))..  f(o,d) =l=  z(o,d);
5004   
5005  cand_zero(i,j)$(candidates(i,j)=0)..  a(i,j) =e= 0;
5006   
5007  zij_bigM_lb(i,j,o,d)..  zij(i,j,o,d) =g= f(o,d) - (1 - fij(i,j,o,d));
5008  zij_leq_f(i,j,o,d)..    zij(i,j,o,d) =l= f(o,d);
5009  zij_leq_Mfij(i,j,o,d).. zij(i,j,o,d) =l= fij(i,j,o,d);
5010   
5011  * ---------- PWL con convex combination + binarios ----------
5012  def_xlen(o,d)$(ord(o)<>ord(d))..
5013      xlen(o,d) =e= sum((i,j), fij(i,j,o,d) * logit_coef*(-travel_time(i,j))) + z(o,d)*logit_coef*(-prices(o,d));
5014   
5015  alfaseg_sum(o,d)$(ord(o)<>ord(d)).. sum(seg,alfaseg(seg,o,d)) =e= 1;
5016   
5017  delta_bound(seg,o,d)$((ord(o)<>ord(d)) and (ord(seg) lt card(seg))).. delta(seg,o,d) =l= alfaseg(seg,o,d)*(b(seg+1,o,d)-b(seg,o,d));
5018   
5019  delta_bound_last(seg,o,d)$(ord(seg)=card(seg))..  delta(seg,o,d) =l= alfaseg(seg,o,d)*(-b(seg,o,d));
5020   
5021  xlen_interp(o,d)$(ord(o)<>ord(d)).. xlen(o,d) =e= sum(seg,alfaseg(seg,o,d)*b(seg,o,d) + delta(seg,o,d));
5022   
5023  slice_bound(seg,o,d)$((ord(seg) lt card(seg)) and (ord(o)<>ord(d)) ).. b(seg,o,d) + delta(seg,o,d) =l= b(seg+1,o,d);
5024   
5025  ghat_interp(o,d)$(ord(o)<>ord(d)).. ghat(o,d) =e= sum(seg,alfaseg(seg,o,d)*bord(seg,o,d) + mreg(seg,o,d)*delta(seg,o,d));
5026   
5027  f_leq_ghat(o,d)$(ord(o)<>ord(d))..     f(o,d) =l= ghat(o,d);
5028   
5029   
5030  * ---------- Modelo y resolución ----------
5031  Model netdesign /
5032      def_bud,
5033      def_op_obj,
5034      def_pax_obj,
5035      def_obj,
5036      bigM_s,
5037      bigM_sh,
5038      bigM_a,
5039      relssh,
5040      bud_avail,
5041      link_cap,
5042      station_cap,
5043      hub_connect_cap, hub_direct_cap,
5044      tot_links,
5045      link_sym,
5046      fij_od_flow, fij_do_flow, fij_trans
5047      diag_zero_fo, fij_zero_diag, fij_zero_oo, fij_zero_dd
5048      split_fd, f_leq_Mz
5049      cand_zero
5050      zij_bigM_lb,
5051      zij_leq_f, zij_leq_Mfij
5052      def_xlen
5053      alfaseg_sum
5054      delta_bound
5055      delta_bound_last
5056      slice_bound
5057      xlen_interp
5058      ghat_interp,
5059      f_leq_ghat
5060  /;
5061   
5062   
5063   
5064   
5065  option threads = 60;
5066  option mip     = cplex;
5067   
5068  option reslim = 60;
5069   
5070  Parameter mipgap;
5071   
5072   
5073  Solve netdesign using mip minimizing obj;
5074   
5075  * ---------- Salidas básicas ----------
5076  *Display f.l, fext.l, fij.l, xlen.l, ghat.l,
5077  *        obj.l, op_obj.l, pax_obj.l,
5078  *        s.l, s_bin.l, a.l, a_bin.l, z.l, b;
5079   
5080  mipgap = abs(netdesign.objval - netdesign.objest) / (1e-9 + abs(netdesign.objval));
5081   
5082  Parameter solverTime;
5083   
5084  solverTime = netdesign.resusd;
5085   
5086  Display b,budget,netdesign.objval, netdesign.objest, mipgap;
5087   
5088   
5089  Parameter fnew(o,i,j,d);
5090   
5091  fnew(o,i,j,d)=fij.l(i,j,o,d);
5092  execute_unload "resultado.gdx";
5093   
