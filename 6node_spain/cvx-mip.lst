 635      bud_final
 636   
 637      flow_start(o,d)     "conservación en origen o para cada destino d != o"
 638      flow_end(o,d)       "conservación en destino d para cada origen o != d"
 639      flow_mid(i,o,d)     "conservación en nodos intermedios i != o,d"
 640   
 641      zero_diag_od(o)
 642      zero_fij_self(i,o,d)
 643      zero_fij_origin(o,i,d)
 644      zero_fij_dest(d,i,o)
 645      zero_diag_odext
 646   
 647      split_choice(o,d)
 648      candidates_zero(i,j)
 649   
 650      fix_s_at_zero(i)
 651      fix_sh_at_zero(i)
 652   
 653      expconef(o,d)
 654      exponefext(o,d)
 655      epigraphf(o,d)
 656      epigraphfext(o,d)
 657   
 658      def_deltasaux(i)
 659   
 660      def_deltaaaux(i,j)
 661   
 662      powercones(i)
 663      powerconea(i,j)
 664   
 665      cuad_cone(i)
 666   
 667      bigms(i)
 668      bigmsh(i)
 669      srelsh(i)
 670   
 671  *rescap
 672  ;
 673   
 674  bigms(i)$(ord(i) gt 0).. s(i) =l= (1e6*sbin(i) );
 675  bigmsh(i).. sh(i) =l= 1e6*shbin(i);
 676  srelsh(i).. shbin(i) =l= sbin(i);
 677   
 678  *---------------------*
 679  * Definición objetivo *
 680  *---------------------*
 681   
 682  * Presupuesto (bud): costes lineales + (si iter<niters) costes fijos aproximados
 683  bud_def..
 684      bud =e= sum(i, station_capacity_slope(i)*(s(i) + sh(i)))
 685           + sum(i,
 686                          station_cost(i)*sbin(i))
 687           + sum(i,
 688                          lam*hub_cost(i)*shbin(i)) ;
 689   
 690   
 691   
 692   
 693  * Operación (op): coste lineal de operar enlaces
 694  op_def..
 695      op =e= 1e-2*sum((i,j), op_link_cost(i,j) * a(i,j));
 696   
 697  * Pasajeros (pax): tiempos/precios en ruta y alternativas + entropías
 698  pax_def..
 699      pax =e= 1e-2*(
 700   
 701      + sum((o,d),alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) * (ft(o,d)))
 702  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
 703   
 704     + sum((o,d), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *(ftext(o,d)
 705     - fext_aux(o,d)*log(n_airlines))) );
 706   
 707   
 708  utility_def..
 709      ut =e= 1e-2*(
 710        sum((o,d)$(ord(o) ne ord(d)),
 711              alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *
 712             ( logit_coef*prices(o,d)*f(o,d) + sum((i,j), (travel_time(i,j))*fij(i,j,o,d)*logit_coef)))
 713   
 714      - sum((o,d), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d)
 715            * alt_utility(o,d)*fext(o,d)) );
 716   
 717   
 718   
 719  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
 720   
 721  *    + 1e-3*sum((o,d), demand(o,d)
 722  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
 723   
 724  *   + 1e-3*sum((o,d), demand(o,d)
 725  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
 726  *    +1e-3*sum(i,deltast(i))
 727  *  + 1e-3*sum(i,
 728  *         1/(congestion_coefs_stations(i)*deltas(i) + epsi))
 729  *    +1e-3*sum((i,j),deltaat(i,j))
 730  *    + 1e-3*sum((i,j),
 731  *          1/(congestion_coefs_links(i,j)*deltaa(i,j) + epsi))
 732  ;
 733   
 734  * Objetivo total
 735  obj_def..
 736      obj =e= 1e-2*(pax + 1e-2*op + ut + 1e3*exceed);
 737   
 738  *---------------------*
 739  * Restricciones       *
 740  *---------------------*
 741   
 742   
 743  bud_avail..
 744      bud =l= budget;
 745   
 746  bud_final..
 747      bud
 748      =l=
 749      budget
 750  ;
 751   
 752   
 753  profitability(o,d).. demand(o,d)*prices(o,d)*f(o,d) =g= sum((i,j),demand(o,d)*fij(i,j,o,d)*op_link_cost(i,j)/(a_nom*tau));
 754   
 755  * Simetría de a_prim
 756  link_sym(i,j)$(ord(i) ne ord(j))..  a(i,j) =e= a(j,i);
 757   
 758  * Capacidad de enlace: sum_{o,d} fij(i,j,o,d)*demand(o,d) <= tau*a(i,j)*a_nom
 759  link_cap(i,j)..
 760      sum((o,d), fij(i,j,o,d)*demand(o,d)) =l= a(i,j)*a_nom*tau ;
 761   
 762   
 763   
 764  station_cap(i)..   sigma * (sum(j$ (ord(j) ne ord(i) ), a(j,i)) + sum(j$ (ord(j) ne ord(i) ), a(i,j))) =l= s(i) + sh(i) ;
 765   
 766  hub_connect_cap(i).. sigma * (sum( (o,d,j)$(ord(o)<>ord(i)),
 767      demand(o,d) * fij(i,j,o,d) / (a_nom * tau))  + sum( (o,d,j)$(ord(d)<>ord(i)),
 768      demand(o,d) * fij(j,i,o,d) / (a_nom * tau))) =l= sh(i);
 769   
 770   
 771  hub_direct_cap(o,d).. sigma * demand(o,d) * fij(o,d,o,d) / (a_nom * tau) =l= sh(o) + sh(d) ;
 772   
 773   
 774  * Límite total de links construidos/operativos
 775  tot_links..
 776      sum((i,j), a(i,j)) =l= a_max;
 777   
 778  * Relación f con flujos saliendo del origen
 779  link_flow_to_f(o,d)..
 780      sum(j, fij(o,j,o,d)) =e= f(o,d);
 781   
 782  * Conservación en nodos de origen (para k!=o): sum_out - sum_in = 1 - fext(o,k)
 783  flow_start(o,d)$(ord(o) ne ord(d))..
 784      ( sum(j, fij(o,j,o,d)) - sum(i, fij(i,o,o,d)) ) =e= 1 - fext(o,d);
 785   
 786  * Conservación en nodos destino (para k!=d): sum_out - sum_in = -1 + fext(k,d)
 787  flow_end(o,d)$(ord(o) ne ord(d))..
 788      ( sum(j, fij(d,j,o,d)) - sum(i, fij(i,d,o,d)) ) =e= -1 + fext(o,d);
 789   
 790  * Conservación en nodos intermedios i != o,d: sum_out - sum_in = 0
 791  flow_mid(i,o,d)$( (ord(o) ne ord(i)) and (ord(i) ne ord(d)) )..
 792      ( sum(j, fij(i,j,o,d)) - sum(j, fij(j,i,o,d)) ) =e= 0;
 793   
 794  * Zeros en diagonal y bloques prohibidos (replican fij(:,o,o,:) == 0, etc.)
 795  zero_diag_od(o)..           f(o,o)    =l= 0;
 796  * fext(o,o)=0:
 797  zero_diag_odext(o)..           fext(o,o)    =l= 0;
 798   
 799  * fij(i,i,*,*) = 0
 800  zero_fij_self(i,o,d)..      fij(i,i,o,d) =l= 0;
 801   
 802  * fij(:,o,o,:) = 0  -> i cualquiera, j=o, o=o, d cualquiera
 803  zero_fij_origin(o,i,d)..    fij(i,o,o,d) =l= 0;
 804   
 805  * fij(d,:,:,d) = 0  -> i=d, j cualquiera, o cualquiera, d=d
 806  zero_fij_dest(d,i,o)..      fij(d,i,o,d) =l= 0;
 807   
 808  * Split: para o!=d, f + fext = 1
 809  split_choice(o,d)$(ord(o) ne ord(d))..
 810      f(o,d) + fext(o,d) =e= 1;
 811   
 812  * Enlaces no candidatesidatos forzados a 0: a_prim(i,j)=0 si ~(i,j) en candidates
 813  candidates_zero(i,j)$(not candidates(i,j))..
 814      a(i,j) =e= 0;
 815   
 816  * Fijaciones en la iteración final si previos pequeños (replica iter==niters … <=0.1)
 817  fix_s_at_zero(i)$( (s_prev(i) <= 0.01) and (iter = niters) )..
 818      s(i) =l= epsi;
 819   
 820  fix_sh_at_zero(i)$( (sh_prev(i) <= 0.01) and (iter = niters) )..
 821      sh(i) =l= epsi;
 822   
 823   
 824  def_f_aux(o,d).. f_aux(o,d) =l= f(o,d) + epsi_f;
 825  def_f_aux2(o,d).. f_aux(o,d) =g= f(o,d) - epsi_f;
 826   
 827   
 828   
 829  def_fext_aux(o,d).. fext_aux(o,d) =l= fext(o,d) + epsi_f;
 830  def_fext_aux2(o,d).. fext_aux(o,d) =g= fext(o,d) - epsi_f;
 831   
 832   
 833  expconef(o,d)..  fy(o,d) =g= f_aux(o,d)*exp(fr(o,d)/f_aux(o,d));
 834   
 835   
 836  exponefext(o,d)..  fyext(o,d) =g= fext_aux(o,d)*exp(frext(o,d)/fext_aux(o,d));
 837   
 838  epigraphf(o,d)..  ft(o,d) =g= -fr(o,d)-f_aux(o,d);
 839   
 840  epigraphfext(o,d)..  ftext(o,d) =g= -frext(o,d)-fext_aux(o,d);
 841   
 842  cuad_cone(i).. t(i) =g= sqr(sh(i) - s(i));
 843   
 844  *rescap(i,j,o,d).. fij(i,j,o,d) =l= capa(i,j);
 845   
 846  *---------------------*
 847  * Bounds básicas      *
 848  *---------------------*
 849  * Ya son positivas; si quieres forzar [0,1] también para f,fext,fij ya está con .up=1
 850  * Para a, s, etc., sin cota superior explícita (ajústalas si procede)
