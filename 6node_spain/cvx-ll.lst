 635      flow_end(o,d)       "conservación en destino d para cada origen o != d"
 636      flow_mid(i,o,d)     "conservación en nodos intermedios i != o,d"
 637   
 638      zero_diag_od(o)
 639      zero_fij_self(i,o,d)
 640      zero_fij_origin(o,i,d)
 641      zero_fij_dest(d,i,o)
 642      zero_diag_odext
 643   
 644      split_choice(o,d)
 645      candidates_zero(i,j)
 646   
 647      fix_s_at_zero(i)
 648      fix_sh_at_zero(i)
 649   
 650      expconef(o,d)
 651      exponefext(o,d)
 652      epigraphf(o,d)
 653      epigraphfext(o,d)
 654   
 655      def_deltasaux(i)
 656   
 657      def_deltaaaux(i,j)
 658   
 659      powercones(i)
 660      powerconea(i,j)
 661   
 662      cuad_cone(i)
 663  *rescap
 664  ;
 665   
 666  *---------------------*
 667  * Definición objetivo *
 668  *---------------------*
 669   
 670  * Presupuesto (bud): costes lineales + (si iter<niters) costes fijos aproximados
 671  bud_def..
 672      bud =e= sum(i, station_capacity_slope(i)*(s(i) + sh(i)))
 673           + sum(i,
 674                          station_cost(i)*(s(i)+sh(i))/((s_prev(i)+sh_prev(i))+epsi))
 675           + sum(i,
 676                          lam*hub_cost(i)*sh(i)/(sh_prev(i)+epsi)) ;
 677   
 678   
 679   
 680   
 681   
 682  * Operación (op): coste lineal de operar enlaces
 683  op_def..
 684      op =e= 1e-3*sum((i,j), op_link_cost(i,j) * a(i,j));
 685   
 686  * Pasajeros (pax): tiempos/precios en ruta y alternativas + entropías
 687  pax_def..
 688      pax =e= 1e-2*(
 689   
 690      + sum((o,d)$(ord(o) ne ord(d)),alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) * (ft(o,d)))
 691  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
 692   
 693     + sum((o,d), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *(ftext(o,d)
 694     - fext_aux(o,d)*log(n_airlines))) );
 695   
 696   
 697  utility_def..
 698      ut =e= 1e-2*(
 699        sum((o,d)$(ord(o) ne ord(d)),
 700              alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *
 701             ( logit_coef*prices(o,d)*f(o,d) + sum((i,j), (travel_time(i,j))*fij(i,j,o,d)*logit_coef)))
 702   
 703      - sum((o,d)$(ord(o) ne ord(d)), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d)
 704            * alt_utility(o,d)*fext(o,d)) );
 705   
 706   
 707   
 708  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
 709   
 710  *    + 1e-3*sum((o,d), demand(o,d)
 711  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
 712   
 713  *   + 1e-3*sum((o,d), demand(o,d)
 714  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
 715  *    +1e-3*sum(i,deltast(i))
 716  *  + 1e-3*sum(i,
 717  *         1/(congestion_coefs_stations(i)*deltas(i) + epsi))
 718  *    +1e-3*sum((i,j),deltaat(i,j))
 719  *    + 1e-3*sum((i,j),
 720  *          1/(congestion_coefs_links(i,j)*deltaa(i,j) + epsi))
 721  ;
 722   
 723  * Objetivo total
 724  obj_def..
 725      obj =e= pax + ut + 1e-6*bud$(iter < niters) + 1e6*exceed + op;
 726   
 727  *+ op + ut + 1e6*exceed + 1e-6*bud$(iter < niters);
 728   
 729   
 730   
 731  *---------------------*
 732  * Restricciones       *
 733  *---------------------*
 734   
 735   
 736  bud_avail..
 737      bud$(iter < niters) =l= budget;
 738   
 739  bud_final..
 740      ( sum(i, station_capacity_slope(i)*(s(i) + sh(i)))   + sum(i$((s_prev(i) > 0.01) or (sh_prev(i) > 0.01)), station_cost(i))
 741    + sum(i$(sh_prev(i) > 0.01), lam*hub_cost(i)))$(iter = niters)
 742      =l=
 743      budget
 744  ;
 745   
 746   
 747  profitability(o,d).. demand(o,d)*prices(o,d)*f(o,d) =g= sum((i,j),demand(o,d)*fij(i,j,o,d)*op_link_cost(i,j)/(a_nom*tau));
 748   
 749  * Simetría de a_prim
 750  link_sym(i,j)$(ord(i) ne ord(j))..  a(i,j) =e= a(j,i);
 751   
 752  * Capacidad de enlace: sum_{o,d} fij(i,j,o,d)*demand(o,d) <= tau*a(i,j)*a_nom
 753  link_cap(i,j)..
 754      sum((o,d), fij(i,j,o,d)*demand(o,d)) =l= a(i,j)*a_nom*tau;
 755   
 756   
 757   
 758  station_cap(i)..   sigma * (sum(j, a(j,i)) + sum(j, a(i,j))) =l= s(i) + sh(i);
 759   
 760   
 761  hub_connect_cap(i).. sigma * (sum( (o,d,j)$(ord(o)<>ord(i)),
 762      demand(o,d) * fij(i,j,o,d) / (a_nom * tau))  + sum( (o,d,j)$(ord(d)<>ord(i)),
 763      demand(o,d) * fij(j,i,o,d) / (a_nom * tau))) =l= sh(i);
 764   
 765   
 766  hub_direct_cap(o,d).. sigma * demand(o,d) * fij(o,d,o,d) / (a_nom * tau) =l= sh(o) + sh(d);
 767   
 768   
 769  * Límite total de links construidos/operativos
 770  tot_links..
 771      sum((i,j), a(i,j)) =l= a_max;
 772   
 773  * Relación f con flujos saliendo del origen
 774  link_flow_to_f(o,d)..
 775      sum(j, fij(o,j,o,d)) =e= f(o,d);
 776   
 777  * Conservación en nodos de origen (para k!=o): sum_out - sum_in = 1 - fext(o,k)
 778  flow_start(o,d)$(ord(o) ne ord(d))..
 779      ( sum(j, fij(o,j,o,d)) - sum(i, fij(i,o,o,d)) ) =e= 1 - fext(o,d);
 780   
 781  * Conservación en nodos destino (para k!=d): sum_out - sum_in = -1 + fext(k,d)
 782  flow_end(o,d)$(ord(o) ne ord(d))..
 783      ( sum(j, fij(d,j,o,d)) - sum(i, fij(i,d,o,d)) ) =e= -1 + fext(o,d);
 784   
 785  * Conservación en nodos intermedios i != o,d: sum_out - sum_in = 0
 786  flow_mid(i,o,d)$( (ord(o) ne ord(i)) and (ord(i) ne ord(d)) )..
 787      ( sum(j, fij(i,j,o,d)) - sum(j, fij(j,i,o,d)) ) =e= 0;
 788   
 789  * Zeros en diagonal y bloques prohibidos (replican fij(:,o,o,:) == 0, etc.)
 790  zero_diag_od(o)..           f(o,o)    =l= epsi;
 791  * fext(o,o)=0:
 792  zero_diag_odext(o)..           fext(o,o)    =l= epsi;
 793   
 794  * fij(i,i,*,*) = 0
 795  zero_fij_self(i,o,d)..      fij(i,i,o,d) =l= epsi;
 796   
 797  * fij(:,o,o,:) = 0  -> i cualquiera, j=o, o=o, d cualquiera
 798  zero_fij_origin(o,i,d)..    fij(i,o,o,d) =l= epsi;
 799   
 800  * fij(d,:,:,d) = 0  -> i=d, j cualquiera, o cualquiera, d=d
 801  zero_fij_dest(d,i,o)..      fij(d,i,o,d) =l= epsi;
 802   
 803  * Split: para o!=d, f + fext = 1
 804  split_choice(o,d)$(ord(o) ne ord(d))..
 805      f(o,d) + fext(o,d) =e= 1;
 806   
 807  * Enlaces no candidatesidatos forzados a 0: a_prim(i,j)=0 si ~(i,j) en candidates
 808  candidates_zero(i,j)$(not candidates(i,j))..
 809      a(i,j) =e= 0;
 810   
 811  * Fijaciones en la iteración final si previos pequeños (replica iter==niters … <=0.1)
 812  fix_s_at_zero(i)$( (s_prev(i) <= 0.01) and (iter = niters) )..
 813      s(i) =l= epsi;
 814   
 815  fix_sh_at_zero(i)$( (sh_prev(i) <= 0.01) and (iter = niters) )..
 816      sh(i) =l= epsi;
 817   
 818   
 819  def_f_aux(o,d).. f_aux(o,d) =l= f(o,d) + epsi_f;
 820  def_f_aux2(o,d).. f_aux(o,d) =g= f(o,d) - epsi_f;
 821   
 822   
 823   
 824  def_fext_aux(o,d).. fext_aux(o,d) =l= fext(o,d) + epsi_f;
 825  def_fext_aux2(o,d).. fext_aux(o,d) =g= fext(o,d) - epsi_f;
 826   
 827   
 828  expconef(o,d)..  fy(o,d) =g= f_aux(o,d)*exp(fr(o,d)/f_aux(o,d));
 829   
 830   
 831  exponefext(o,d)..  fyext(o,d) =g= fext_aux(o,d)*exp(frext(o,d)/fext_aux(o,d));
 832   
 833  epigraphf(o,d)..  ft(o,d) =g= -fr(o,d)-f_aux(o,d);
 834   
 835  epigraphfext(o,d)..  ftext(o,d) =g= -frext(o,d)-fext_aux(o,d);
 836   
 837  cuad_cone(i).. t(i) =g= sqr(sh(i) - s(i));
 838   
 839  *rescap(i,j,o,d).. fij(i,j,o,d) =l= capa(i,j);
 840   
