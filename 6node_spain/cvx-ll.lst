 628   
 629      profitability(o,d)
 630   
 631      bud_avail
 632      bud_final
 633   
 634      flow_start(o,d)     "conservación en origen o para cada destino d != o"
 635      flow_end(o,d)       "conservación en destino d para cada origen o != d"
 636      flow_mid(i,o,d)     "conservación en nodos intermedios i != o,d"
 637   
 638      zero_diag_od(o)
 639      zero_fij_self(i,o,d)
 640      zero_fij_origin(o,i,d)
 641      zero_fij_dest(d,i,o)
 642      zero_diag_odext
 643   
 644      split_choice(o,d)
 645      candidates_zero(i,j)
 646   
 647      fix_s_at_zero(i)
 648      fix_sh_at_zero(i)
 649   
 650      expconef(o,d)
 651      exponefext(o,d)
 652      epigraphf(o,d)
 653      epigraphfext(o,d)
 654   
 655      def_deltasaux(i)
 656   
 657      def_deltaaaux(i,j)
 658   
 659      powercones(i)
 660      powerconea(i,j)
 661   
 662      cuad_cone(i)
 663   
 664  *rescap
 665  ;
 666   
 667  *---------------------*
 668  * Definición objetivo *
 669  *---------------------*
 670   
 671  * Presupuesto (bud): costes lineales + (si iter<niters) costes fijos aproximados
 672  bud_def..
 673      bud =e= sum(i, station_capacity_slope(i)*(s(i) + sh(i)))
 674           + sum(i,
 675                          station_cost(i)*(s(i)+sh(i))/((s_prev(i)+sh_prev(i))+epsi))
 676           + sum(i,
 677                          lam*hub_cost(i)*sh(i)/(sh_prev(i)+epsi)) ;
 678   
 679   
 680   
 681   
 682   
 683  * Operación (op): coste lineal de operar enlaces
 684  op_def..
 685      op =e= 1e-2*sum((i,j), op_link_cost(i,j) * a(i,j));
 686   
 687  * Pasajeros (pax): tiempos/precios en ruta y alternativas + entropías
 688  pax_def..
 689      pax =e= 1e-2*(
 690   
 691      + sum((o,d),alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) * (ft(o,d)))
 692  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
 693   
 694     + sum((o,d), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *(ftext(o,d)
 695     - fext_aux(o,d)*log(n_airlines))) );
 696   
 697   
 698  utility_def..
 699      ut =e= 1e-2*(
 700        sum((o,d)$(ord(o) ne ord(d)),
 701              alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *
 702             ( logit_coef*prices(o,d)*f(o,d) + sum((i,j), (travel_time(i,j))*fij(i,j,o,d)*logit_coef)))
 703   
 704      - sum((o,d), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d)
 705            * alt_utility(o,d)*fext(o,d)) );
 706   
 707   
 708   
 709  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
 710   
 711  *    + 1e-3*sum((o,d), demand(o,d)
 712  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
 713   
 714  *   + 1e-3*sum((o,d), demand(o,d)
 715  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
 716  *    +1e-3*sum(i,deltast(i))
 717  *  + 1e-3*sum(i,
 718  *         1/(congestion_coefs_stations(i)*deltas(i) + epsi))
 719  *    +1e-3*sum((i,j),deltaat(i,j))
 720  *    + 1e-3*sum((i,j),
 721  *          1/(congestion_coefs_links(i,j)*deltaa(i,j) + epsi))
 722  ;
 723   
 724  * Objetivo total
 725  obj_def..
 726      obj =e= pax + op + ut + 1e3*exceed + 1e-6*bud;
 727   
 728  *---------------------*
 729  * Restricciones       *
 730  *---------------------*
 731   
 732   
 733  bud_avail..
 734      bud =l= budget;
 735   
 736  bud_final..
 737      ( sum(i, station_capacity_slope(i)*(s(i) + sh(i)))   + sum(i$((s_prev(i) > 0.01) or (sh_prev(i) > 0.01)), station_cost(i))
 738    + sum(i$(sh_prev(i) > 0.01), lam*hub_cost(i)))$(iter = niters) - exceed
 739      =l=
 740      budget
 741  ;
 742   
 743   
 744  profitability(o,d).. demand(o,d)*prices(o,d)*f(o,d) =g= sum((i,j),demand(o,d)*fij(i,j,o,d)*op_link_cost(i,j)/(a_nom*tau));
 745   
 746  * Simetría de a_prim
 747  link_sym(i,j)$(ord(i) ne ord(j))..  a(i,j) =e= a(j,i);
 748   
 749  * Capacidad de enlace: sum_{o,d} fij(i,j,o,d)*demand(o,d) <= tau*a(i,j)*a_nom
 750  link_cap(i,j)..
 751      sum((o,d), fij(i,j,o,d)*demand(o,d)) =l= a(i,j)*a_nom*tau;
 752   
 753   
 754   
 755  station_cap(i)..   sigma * (sum(j, a(j,i)) + sum(j, a(i,j))) =l= s(i) + sh(i);
 756   
 757  hub_connect_cap(i).. sigma * (sum( (o,d,j)$(ord(o)<>ord(i)),
 758      demand(o,d) * fij(i,j,o,d) / (a_nom * tau))  + sum( (o,d,j)$(ord(d)<>ord(i)),
 759      demand(o,d) * fij(j,i,o,d) / (a_nom * tau))) =l= sh(i);
 760   
 761   
 762  hub_direct_cap(o,d).. sigma * demand(o,d) * fij(o,d,o,d) / (a_nom * tau) =l= sh(o) + sh(d);
 763   
 764   
 765  * Límite total de links construidos/operativos
 766  tot_links..
 767      sum((i,j), a(i,j)) =l= a_max;
 768   
 769  * Relación f con flujos saliendo del origen
 770  link_flow_to_f(o,d)..
 771      sum(j, fij(o,j,o,d)) =e= f(o,d);
 772   
 773  * Conservación en nodos de origen (para k!=o): sum_out - sum_in = 1 - fext(o,k)
 774  flow_start(o,d)$(ord(o) ne ord(d))..
 775      ( sum(j, fij(o,j,o,d)) - sum(i, fij(i,o,o,d)) ) =e= 1 - fext(o,d);
 776   
 777  * Conservación en nodos destino (para k!=d): sum_out - sum_in = -1 + fext(k,d)
 778  flow_end(o,d)$(ord(o) ne ord(d))..
 779      ( sum(j, fij(d,j,o,d)) - sum(i, fij(i,d,o,d)) ) =e= -1 + fext(o,d);
 780   
 781  * Conservación en nodos intermedios i != o,d: sum_out - sum_in = 0
 782  flow_mid(i,o,d)$( (ord(o) ne ord(i)) and (ord(i) ne ord(d)) )..
 783      ( sum(j, fij(i,j,o,d)) - sum(j, fij(j,i,o,d)) ) =e= 0;
 784   
 785  * Zeros en diagonal y bloques prohibidos (replican fij(:,o,o,:) == 0, etc.)
 786  zero_diag_od(o)..           f(o,o)    =l= epsi;
 787  * fext(o,o)=0:
 788  zero_diag_odext(o)..           fext(o,o)    =l= epsi;
 789   
 790  * fij(i,i,*,*) = 0
 791  zero_fij_self(i,o,d)..      fij(i,i,o,d) =l= epsi;
 792   
 793  * fij(:,o,o,:) = 0  -> i cualquiera, j=o, o=o, d cualquiera
 794  zero_fij_origin(o,i,d)..    fij(i,o,o,d) =l= epsi;
 795   
 796  * fij(d,:,:,d) = 0  -> i=d, j cualquiera, o cualquiera, d=d
 797  zero_fij_dest(d,i,o)..      fij(d,i,o,d) =l= epsi;
 798   
 799  * Split: para o!=d, f + fext = 1
 800  split_choice(o,d)$(ord(o) ne ord(d))..
 801      f(o,d) + fext(o,d) =e= 1;
 802   
 803  * Enlaces no candidatesidatos forzados a 0: a_prim(i,j)=0 si ~(i,j) en candidates
 804  candidates_zero(i,j)$(not candidates(i,j))..
 805      a(i,j) =e= 0;
 806   
 807  * Fijaciones en la iteración final si previos pequeños (replica iter==niters … <=0.1)
 808  fix_s_at_zero(i)$( (s_prev(i) <= 0.01) and (iter = niters) )..
 809      s(i) =l= epsi;
 810   
 811  fix_sh_at_zero(i)$( (sh_prev(i) <= 0.01) and (iter = niters) )..
 812      sh(i) =l= epsi;
 813   
 814   
 815  def_f_aux(o,d).. f_aux(o,d) =l= f(o,d) + epsi_f;
 816  def_f_aux2(o,d).. f_aux(o,d) =g= f(o,d) - epsi_f;
 817   
 818   
 819   
 820  def_fext_aux(o,d).. fext_aux(o,d) =l= fext(o,d) + epsi_f;
 821  def_fext_aux2(o,d).. fext_aux(o,d) =g= fext(o,d) - epsi_f;
 822   
 823   
 824  expconef(o,d)..  fy(o,d) =g= f_aux(o,d)*exp(fr(o,d)/f_aux(o,d));
 825   
 826   
 827  exponefext(o,d)..  fyext(o,d) =g= fext_aux(o,d)*exp(frext(o,d)/fext_aux(o,d));
 828   
 829  epigraphf(o,d)..  ft(o,d) =g= -fr(o,d)-f_aux(o,d);
 830   
 831  epigraphfext(o,d)..  ftext(o,d) =g= -frext(o,d)-fext_aux(o,d);
 832   
 833  cuad_cone(i).. t(i) =g= sqr(sh(i) - s(i));
 834   
 835  *rescap(i,j,o,d).. fij(i,j,o,d) =l= capa(i,j);
