 634      flow_mid(i,o,d)     "conservación en nodos intermedios i != o,d"
 635   
 636      zero_diag_od(o)
 637      zero_fij_self(i,o,d)
 638      zero_fij_origin(o,i,d)
 639      zero_fij_dest(d,i,o)
 640      zero_diag_odext
 641   
 642      split_choice(o,d)
 643      candidates_zero(i,j)
 644   
 645      fix_s_at_zero(i)
 646      fix_sh_at_zero(i)
 647   
 648      expconef(o,d)
 649      exponefext(o,d)
 650      epigraphf(o,d)
 651      epigraphfext(o,d)
 652   
 653      def_deltasaux(i)
 654      def_deltaaaux(i,j)
 655      powercones(i)
 656      powerconea(i,j)
 657      f_bounds_logit(o,d)
 658   
 659      station_cap_first_iter(i)
 660   
 661  *rescap
 662  ;
 663   
 664  *---------------------*
 665  * Definición objetivo *
 666  *---------------------*
 667   
 668  ul_def..
 669      ul =e= 1e-2*(-sum((o,d)$(ord(o) ne ord(d)),prices(o,d)*demand(o,d)*f(o,d) ) + sum((i,j), op_link_cost(i,j) * a(i,j))) ;
 670   
 671   
 672  * Presupuesto (bud): costes lineales + (si iter<niters) costes fijos aproximados
 673  bud_def..
 674      bud =e= sum(i, station_capacity_slope(i)*(s(i) + 1.01*sh(i)))
 675           + sum(i,
 676                          station_cost(i)*(s(i)+1.01*sh(i))/((s_prev(i)+sh_prev(i))+epsi))
 677           + sum(i,
 678                          lam*hub_cost(i)*sh(i)/(sh_prev(i)+epsi));
 679   
 680   
 681   
 682   
 683   
 684  * Operación (op): coste lineal de operar enlaces
 685  op_def..
 686      op =e= 1e-3*sum((i,j), op_link_cost(i,j) * a(i,j));
 687   
 688  * Pasajeros (pax): tiempos/precios en ruta y alternativas + entropías
 689  pax_def..
 690      pax =e= 1e-2*(
 691        sum((o,d)$(ord(o) ne ord(d)),
 692              alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *
 693             ( logit_coef*prices(o,d)*f(o,d) + sum((i,j), travel_time(i,j)*fij(i,j,o,d)*logit_coef)))
 694   
 695      - sum((o,d)$(ord(o) ne ord(d)), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d)
 696            * alt_utility(o,d)*fext(o,d))
 697   
 698      + sum((o,d)$(ord(o) ne ord(d)),alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) * (ft(o,d)))
 699  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
 700   
 701     + sum((o,d)$(ord(o) ne ord(d)), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *(ftext(o,d)
 702     - fext_aux(o,d)*log(n_airlines))) )
 703   
 704   
 705   
 706   
 707  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
 708   
 709  *    + 1e-3*sum((o,d), demand(o,d)
 710  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
 711   
 712  *   + 1e-3*sum((o,d), demand(o,d)
 713  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
 714  *    +1e-3*sum(i,deltast(i))
 715  *  + 1e-3*sum(i,
 716  *         1/(congestion_coefs_stations(i)*deltas(i) + epsi))
 717  *    +1e-3*sum((i,j),deltaat(i,j))
 718  *    + 1e-3*sum((i,j),
 719  *          1/(congestion_coefs_links(i,j)*deltaa(i,j) + epsi))
 720  ;
 721   
 722  * Objetivo total
 723  obj_def..
 724      obj =e= ul + 5e-2*gamma_*(pax + op + 1e3*exceed + 1e-6*bud);
 725   
 726  *---------------------*
 727  * Restricciones       *
 728  *---------------------*
 729   
 730   
 731  bud_avail..
 732      bud =l= budget;
 733   
 734  bud_final..
 735      ( sum(i, station_capacity_slope(i)*(s(i) + sh(i)))   + sum(i$((s_prev(i) > 0.01) or (sh_prev(i) > 0.01)), station_cost(i))
 736    + sum(i$(sh_prev(i) > 0.01), lam*hub_cost(i)))$(iter = niters) - exceed
 737      =l=
 738      budget
 739  ;
 740   
 741   
 742  profitability(o,d).. demand(o,d)*prices(o,d)*f(o,d) =g= sum((i,j),demand(o,d)*fij(i,j,o,d)*op_link_cost(i,j)/(a_nom*tau));
 743   
 744  * Simetría de a_prim
 745  link_sym(i,j)$(ord(i) ne ord(j))..  a(i,j) =e= a(j,i);
 746   
 747  * Capacidad de enlace: sum_{o,d} fij(i,j,o,d)*demand(o,d) <= tau*a(i,j)*a_nom
 748  link_cap(i,j)..
 749      sum((o,d), fij(i,j,o,d)*demand(o,d)) =l= a(i,j)*a_nom*tau;
 750   
 751   
 752   
 753  station_cap(i)..   sigma * (sum(j, a(j,i)) + sum(j, a(i,j))) =l= s(i) + sh(i);
 754   
 755  station_cap_first_iter(i)$(iter <= 1).. sigma * (sum(j, a(j,i)) + sum(j, a(i,j))) =l= sh(i);
 756   
 757  hub_connect_cap(i).. sigma * (sum( (o,d,j)$(ord(o)<>ord(i)),
 758      demand(o,d) * fij(i,j,o,d) / (a_nom * tau))  + sum( (o,d,j)$(ord(d)<>ord(i)),
 759      demand(o,d) * fij(j,i,o,d) / (a_nom * tau))) =l= sh(i);
 760   
 761   
 762  hub_direct_cap(o,d).. sigma * demand(o,d) * fij(o,d,o,d) / (a_nom * tau) =l= sh(o) + sh(d);
 763   
 764   
 765  * Límite total de links construidos/operativos
 766  tot_links..
 767      sum((i,j), a(i,j)) =l= a_max;
 768   
 769  * Relación f con flujos saliendo del origen
 770  link_flow_to_f(o,d)..
 771      sum(j, fij(o,j,o,d)) =e= f(o,d);
 772   
 773  * Conservación en nodos de origen (para k!=o): sum_out - sum_in = 1 - fext(o,k)
 774  flow_start(o,d)$(ord(o) ne ord(d))..
 775      ( sum(j, fij(o,j,o,d)) - sum(i, fij(i,o,o,d)) ) =e= 1 - fext(o,d);
 776   
 777  * Conservación en nodos destino (para k!=d): sum_out - sum_in = -1 + fext(k,d)
 778  flow_end(o,d)$(ord(o) ne ord(d))..
 779      ( sum(j, fij(d,j,o,d)) - sum(i, fij(i,d,o,d)) ) =e= -1 + fext(o,d);
 780   
 781  * Conservación en nodos intermedios i != o,d: sum_out - sum_in = 0
 782  flow_mid(i,o,d)$( (ord(o) ne ord(i)) and (ord(i) ne ord(d)) )..
 783      ( sum(j, fij(i,j,o,d)) - sum(j, fij(j,i,o,d)) ) =e= 0;
 784   
 785  * Zeros en diagonal y bloques prohibidos (replican fij(:,o,o,:) == 0, etc.)
 786  zero_diag_od(o)..           f(o,o)    =l= epsi;
 787  * fext(o,o)=0:
 788  zero_diag_odext(o)..           fext(o,o)    =l= epsi;
 789   
 790  * fij(i,i,*,*) = 0
 791  zero_fij_self(i,o,d)..      fij(i,i,o,d) =l= epsi;
 792   
 793  * fij(:,o,o,:) = 0  -> i cualquiera, j=o, o=o, d cualquiera
 794  zero_fij_origin(o,i,d)..    fij(i,o,o,d) =l= epsi;
 795   
 796  * fij(d,:,:,d) = 0  -> i=d, j cualquiera, o cualquiera, d=d
 797  zero_fij_dest(d,i,o)..      fij(d,i,o,d) =l= epsi;
 798   
 799  * Split: para o!=d, f + fext = 1
 800  split_choice(o,d)$(ord(o) ne ord(d))..
 801      f(o,d) + fext(o,d) =e= 1;
 802   
 803  * Enlaces no candidatesidatos forzados a 0: a_prim(i,j)=0 si ~(i,j) en candidates
 804  candidates_zero(i,j)$(not candidates(i,j))..
 805      a(i,j) =e= 0;
 806   
 807  * Fijaciones en la iteración final si previos pequeños (replica iter==niters … <=0.1)
 808  fix_s_at_zero(i)$( (s_prev(i) <= 0.01) and (iter = niters) )..
 809      s(i) =l= epsi;
 810   
 811  fix_sh_at_zero(i)$( (sh_prev(i) <= 0.01) and (iter = niters) )..
 812      sh(i) =l= epsi;
 813   
 814   
 815  def_f_aux(o,d).. f_aux(o,d) =e= f(o,d) + epsi_f;
 816  def_fext_aux(o,d).. fext_aux(o,d) =e= fext(o,d) + epsi_f;
 817   
 818   
 819  expconef(o,d)..  fy(o,d) =g= f_aux(o,d)*exp(fr(o,d)/f_aux(o,d));
 820   
 821   
 822  exponefext(o,d)..  fyext(o,d) =g= fext_aux(o,d)*exp(frext(o,d)/fext_aux(o,d));
 823   
 824  epigraphf(o,d)..  ft(o,d) =g= -fr(o,d)-f_aux(o,d);
 825   
 826  epigraphfext(o,d)..  ftext(o,d) =g= -frext(o,d)-fext_aux(o,d);
 827   
 828   
 829  f_bounds_logit(o,d).. f(o,d) =l= f_bounds(o,d);
 830  *rescap(i,j,o,d).. fij(i,j,o,d) =l= capa(i,j);
 831   
 832  *---------------------*
 833  * Bounds básicas      *
 834  *---------------------*
 835  * Ya son positivas; si quieres forzar [0,1] también para f,fext,fij ya está con .up=1
 836  * Para a, s, etc., sin cota superior explícita (ajústalas si procede)
