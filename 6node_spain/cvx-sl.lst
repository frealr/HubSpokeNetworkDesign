1007  loop(i$( sh.l(i) gt 3e-2 ),
1008      loop(j$( (sh.l(j) gt 3e-2) and (conecta(j) lt 1) and (a.l(i,j) gt 1e-3) ),
1009      sobra(i) = 0 )
1010  );
