1000   
1001  loop(i$( sh.l(i) gt 3e-2 ),
1002      loop(j$( ((sh.l(j) lt 3e-2) and (a.l(i,j) gt 1e-3))  ),
1003      sobra(i) = 0 )
1004  );
1005   
