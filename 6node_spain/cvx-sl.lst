 630      bud_final
 631   
 632      flow_start(o,d)     "conservación en origen o para cada destino d != o"
 633      flow_end(o,d)       "conservación en destino d para cada origen o != d"
 634      flow_mid(i,o,d)     "conservación en nodos intermedios i != o,d"
 635   
 636      zero_diag_od(o)
 637      zero_fij_self(i,o,d)
 638      zero_fij_origin(o,i,d)
 639      zero_fij_dest(d,i,o)
 640      zero_diag_odext
 641   
 642      split_choice(o,d)
 643      candidates_zero(i,j)
 644   
 645      fix_s_at_zero(i)
 646      fix_sh_at_zero(i)
 647   
 648      expconef(o,d)
 649      exponefext(o,d)
 650      epigraphf(o,d)
 651      epigraphfext(o,d)
 652   
 653      def_deltasaux(i)
 654      def_deltaaaux(i,j)
 655      powercones(i)
 656      powerconea(i,j)
 657      f_bounds_logit(o,d)
 658   
 659  *rescap
 660  ;
 661   
 662  *---------------------*
 663  * Definición objetivo *
 664  *---------------------*
 665   
 666  ul_def..
 667      ul =e= 1e-2*(-sum((o,d),prices(o,d)*demand(o,d)*f(o,d) ) + sum((i,j), op_link_cost(i,j) * a(i,j))) ;
 668   
 669   
 670  * Presupuesto (bud): costes lineales + (si iter<niters) costes fijos aproximados
 671  bud_def..
 672      bud =e= sum(i, station_capacity_slope(i)*(s(i) + 1.01*sh(i)))
 673           + sum(i,
 674                          station_cost(i)*(s(i)+1.01*sh(i))/((s_prev(i)+sh_prev(i))+epsi))
 675           + sum(i,
 676                          lam*hub_cost(i)*sh(i)/(sh_prev(i)+epsi));
 677   
 678   
 679   
 680   
 681   
 682  * Operación (op): coste lineal de operar enlaces
 683  op_def..
 684      op =e= 1e-2*sum((i,j), op_link_cost(i,j) * a(i,j));
 685   
 686  * Pasajeros (pax): tiempos/precios en ruta y alternativas + entropías
 687  pax_def..
 688      pax =e= 1e-2*(
 689        sum((o,d),
 690              alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *
 691             ( logit_coef*prices(o,d)*f(o,d) + sum((i,j), travel_time(i,j)*fij(i,j,o,d)*logit_coef)))
 692   
 693      - sum((o,d), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d)
 694            * alt_utility(o,d)*fext(o,d))
 695   
 696      + sum((o,d),alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) * (ft(o,d)))
 697  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
 698   
 699     + sum((o,d), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *(ftext(o,d)
 700     - fext_aux(o,d)*log(n_airlines))) )
 701   
 702   
 703   
 704   
 705  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
 706   
 707  *    + 1e-3*sum((o,d), demand(o,d)
 708  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
 709   
 710  *   + 1e-3*sum((o,d), demand(o,d)
 711  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
 712  *    +1e-3*sum(i,deltast(i))
 713  *  + 1e-3*sum(i,
 714  *         1/(congestion_coefs_stations(i)*deltas(i) + epsi))
 715  *    +1e-3*sum((i,j),deltaat(i,j))
 716  *    + 1e-3*sum((i,j),
 717  *          1/(congestion_coefs_links(i,j)*deltaa(i,j) + epsi))
 718  ;
 719   
 720  * Objetivo total
 721  obj_def..
 722      obj =e= ul + 5e-2*gamma_*(pax + op + 1e3*exceed + 1e-6*bud);
 723   
 724  *---------------------*
 725  * Restricciones       *
 726  *---------------------*
 727   
 728   
 729  bud_avail..
 730      bud =l= budget;
 731   
 732  bud_final..
 733      ( sum(i, station_capacity_slope(i)*(s(i) + sh(i)))   + sum(i$((s_prev(i) > 0.01) or (sh_prev(i) > 0.01)), station_cost(i))
 734    + sum(i$(sh_prev(i) > 0.01), lam*hub_cost(i)))$(iter = niters) - exceed
 735      =l=
 736      budget
 737  ;
 738   
 739   
 740  profitability(o,d).. demand(o,d)*prices(o,d)*f(o,d) =g= sum((i,j),demand(o,d)*fij(i,j,o,d)*op_link_cost(i,j)/(a_nom*tau));
 741   
 742  * Simetría de a_prim
 743  link_sym(i,j)$(ord(i) ne ord(j))..  a(i,j) =e= a(j,i);
 744   
 745  * Capacidad de enlace: sum_{o,d} fij(i,j,o,d)*demand(o,d) <= tau*a(i,j)*a_nom
 746  link_cap(i,j)..
 747      sum((o,d), fij(i,j,o,d)*demand(o,d)) =l= a(i,j)*a_nom*tau;
 748   
 749   
 750   
 751  station_cap(i)..   sigma * (sum(j, a(j,i)) + sum(j, a(i,j))) =l= s(i) + sh(i);
 752   
 753  hub_connect_cap(i).. sigma * (sum( (o,d,j)$(ord(o)<>ord(i)),
 754      demand(o,d) * fij(i,j,o,d) / (a_nom * tau))  + sum( (o,d,j)$(ord(d)<>ord(i)),
 755      demand(o,d) * fij(j,i,o,d) / (a_nom * tau))) =l= sh(i);
 756   
 757   
 758  hub_direct_cap(o,d).. sigma * demand(o,d) * fij(o,d,o,d) / (a_nom * tau) =l= sh(o) + sh(d);
 759   
 760   
 761  * Límite total de links construidos/operativos
 762  tot_links..
 763      sum((i,j), a(i,j)) =l= a_max;
 764   
 765  * Relación f con flujos saliendo del origen
 766  link_flow_to_f(o,d)..
 767      sum(j, fij(o,j,o,d)) =e= f(o,d);
 768   
 769  * Conservación en nodos de origen (para k!=o): sum_out - sum_in = 1 - fext(o,k)
 770  flow_start(o,d)$(ord(o) ne ord(d))..
 771      ( sum(j, fij(o,j,o,d)) - sum(i, fij(i,o,o,d)) ) =e= 1 - fext(o,d);
 772   
 773  * Conservación en nodos destino (para k!=d): sum_out - sum_in = -1 + fext(k,d)
 774  flow_end(o,d)$(ord(o) ne ord(d))..
 775      ( sum(j, fij(d,j,o,d)) - sum(i, fij(i,d,o,d)) ) =e= -1 + fext(o,d);
 776   
 777  * Conservación en nodos intermedios i != o,d: sum_out - sum_in = 0
 778  flow_mid(i,o,d)$( (ord(o) ne ord(i)) and (ord(i) ne ord(d)) )..
 779      ( sum(j, fij(i,j,o,d)) - sum(j, fij(j,i,o,d)) ) =e= 0;
 780   
 781  * Zeros en diagonal y bloques prohibidos (replican fij(:,o,o,:) == 0, etc.)
 782  zero_diag_od(o)..           f(o,o)    =l= epsi;
 783  * fext(o,o)=0:
 784  zero_diag_odext(o)..           fext(o,o)    =l= epsi;
 785   
 786  * fij(i,i,*,*) = 0
 787  zero_fij_self(i,o,d)..      fij(i,i,o,d) =l= epsi;
 788   
 789  * fij(:,o,o,:) = 0  -> i cualquiera, j=o, o=o, d cualquiera
 790  zero_fij_origin(o,i,d)..    fij(i,o,o,d) =l= epsi;
 791   
 792  * fij(d,:,:,d) = 0  -> i=d, j cualquiera, o cualquiera, d=d
 793  zero_fij_dest(d,i,o)..      fij(d,i,o,d) =l= epsi;
 794   
 795  * Split: para o!=d, f + fext = 1
 796  split_choice(o,d)$(ord(o) ne ord(d))..
 797      f(o,d) + fext(o,d) =e= 1;
 798   
 799  * Enlaces no candidatesidatos forzados a 0: a_prim(i,j)=0 si ~(i,j) en candidates
 800  candidates_zero(i,j)$(not candidates(i,j))..
 801      a(i,j) =e= 0;
 802   
 803  * Fijaciones en la iteración final si previos pequeños (replica iter==niters … <=0.1)
 804  fix_s_at_zero(i)$( (s_prev(i) <= 0.01) and (iter = niters) )..
 805      s(i) =l= epsi;
 806   
 807  fix_sh_at_zero(i)$( (sh_prev(i) <= 0.01) and (iter = niters) )..
 808      sh(i) =l= epsi;
 809   
 810   
 811  def_f_aux(o,d).. f_aux(o,d) =e= f(o,d) + epsi_f;
 812  def_fext_aux(o,d).. fext_aux(o,d) =e= fext(o,d) + epsi_f;
 813   
 814   
 815  expconef(o,d)..  fy(o,d) =g= f_aux(o,d)*exp(fr(o,d)/f_aux(o,d));
 816   
 817   
 818  exponefext(o,d)..  fyext(o,d) =g= fext_aux(o,d)*exp(frext(o,d)/fext_aux(o,d));
 819   
 820  epigraphf(o,d)..  ft(o,d) =g= -fr(o,d)-f_aux(o,d);
 821   
 822  epigraphfext(o,d)..  ftext(o,d) =g= -frext(o,d)-fext_aux(o,d);
 823   
 824   
 825  f_bounds_logit(o,d).. f(o,d) =l= f_bounds(o,d);
 826  *rescap(i,j,o,d).. fij(i,j,o,d) =l= capa(i,j);
