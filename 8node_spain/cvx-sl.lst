 857   
 858   
 859  Scalars tau, sigma, a_nom, a_max;
 860  tau = 0.85;
 861  sigma = 0.3;
 862  a_nom = 171;
 863  a_max = 1e7;
 864   
 865  Scalar n; n = card(i);
 866   
 867  Scalar epsi; epsi = 1e-3;
 868   
 869  Scalar lam /
INCLUDE    /home/lcadarso/TFM/HubSpokeNetworkDesign/8node_spain/export_txt/lam.txt
 871  4
 872  /;
 873   
 874  Scalar alfa /
INCLUDE    /home/lcadarso/TFM/HubSpokeNetworkDesign/8node_spain/export_txt/alfa.txt
 876  0.1
 877  /;
 878   
 879   
 880  Scalar iter /
INCLUDE    /home/lcadarso/TFM/HubSpokeNetworkDesign/8node_spain/export_txt/current_iter.txt
 882  20
 883  /;
 884   
 885  Scalar niters /
INCLUDE    /home/lcadarso/TFM/HubSpokeNetworkDesign/8node_spain/export_txt/niters.txt
 887  20
 888  /;
 889   
 890  Scalar gamma_ /
INCLUDE    /home/lcadarso/TFM/HubSpokeNetworkDesign/8node_spain/export_txt/gamma.txt
 892  20
 893  /;
 894   
 895  Scalar logit_coef; logit_coef = 0.02;
 896   
 897  Scalar n_airlines; n_airlines = 5;
 898   
 899  Scalar epsi_f; epsi_f =1e-6;
 900   
 901   
 902   
 903  display travel_time,link_cost,link_capacity_slope,prices,candidates,station_cost,station_capacity_slope,a_max, iter, niters, demand;
 904   
 905   
 906   
 907  *---------------------*
 908  * Variables           *
 909  *---------------------*
 910   
 911   
 912  Nonnegative Variable
 913      s(i),     sh(i),
 914      a(i,j),
 915      f(o,d),      fext(o,d), f_aux(o,d), fext_aux(o,d),
 916      fij(i,j,o,d), exceed
 917      ;
 918   
 919  Variable bud, op, pax, obj, ft(o,d),ftext(o,d),fr(o,d),frext(o,d),fy(o,d),fyext(o,d),ul;
 920   
 921   
 922   
 923  *---------------------*
 924  * Ecuaciones          *
 925  *---------------------*
 926  Equation
 927      bud_def      "definición de bud_obj"
 928      op_def       "definición de op_obj"
 929      pax_def      "definición de pax_obj"
 930      obj_def      "objetivo total"
 931      ul_def
 932   
 933      def_f_aux
 934      def_fext_aux
 935   
 936      link_sym(i,j)
 937      prim_s_def(i)
 938      prim_a_def(i,j)
 939   
 940      link_cap(i,j)
 941      station_cap(i)
 942      hub_connect_cap(i)
 943      hub_direct_cap(o,d)
 944   
 945      tot_links
 946      link_flow_to_f(o,d)
 947   
 948      profitability(o,d)
 949   
 950      bud_avail
 951      bud_final
 952   
 953      flow_start(o,d)     "conservación en origen o para cada destino d != o"
 954      flow_end(o,d)       "conservación en destino d para cada origen o != d"
 955      flow_mid(i,o,d)     "conservación en nodos intermedios i != o,d"
 956   
 957      zero_diag_od(o)
 958      zero_fij_self(i,o,d)
 959      zero_fij_origin(o,i,d)
 960      zero_fij_dest(d,i,o)
 961      zero_diag_odext
 962   
 963      split_choice(o,d)
 964      candidates_zero(i,j)
 965   
 966      fix_s_at_zero(i)
 967      fix_sh_at_zero(i)
 968   
 969      expconef(o,d)
 970      exponefext(o,d)
 971      epigraphf(o,d)
 972      epigraphfext(o,d)
 973   
 974      def_deltasaux(i)
 975      def_deltaaaux(i,j)
 976      powercones(i)
 977      powerconea(i,j)
 978      f_bounds_logit(o,d)
 979   
 980  *rescap
 981  ;
 982   
 983  *---------------------*
 984  * Definición objetivo *
 985  *---------------------*
 986   
 987  ul_def..
 988      ul =e= 1e-2*(-sum((o,d)$(ord(o) ne ord(d)),prices(o,d)*demand(o,d)*f(o,d) ) + sum((i,j), op_link_cost(i,j) * a(i,j))) ;
 989   
 990   
 991  * Presupuesto (bud): costes lineales + (si iter<niters) costes fijos aproximados
 992  bud_def..
 993      bud =e= sum(i, station_capacity_slope(i)*(s(i) + 1.01*sh(i)))
 994           + sum(i,
 995                          station_cost(i)*(s(i)+1.01*sh(i))/((s_prev(i)+sh_prev(i))+epsi))
 996           + sum(i,
 997                          lam*hub_cost(i)*sh(i)/(sh_prev(i)+epsi));
 998   
 999   
1000   
1001   
1002   
1003  * Operación (op): coste lineal de operar enlaces
1004  op_def..
1005      op =e= 1e-2*sum((i,j), op_link_cost(i,j) * a(i,j));
1006   
1007  * Pasajeros (pax): tiempos/precios en ruta y alternativas + entropías
1008  pax_def..
1009      pax =e= 1e-2*(
1010        sum((o,d)$(ord(o) ne ord(d)),
1011              alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *
1012             ( logit_coef*prices(o,d)*f(o,d) + sum((i,j), travel_time(i,j)*fij(i,j,o,d)*logit_coef)))
1013   
1014      - sum((o,d)$(ord(o) ne ord(d)), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d)
1015            * alt_utility(o,d)*fext(o,d))
1016   
1017      + sum((o,d)$(ord(o) ne ord(d)),alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) * (ft(o,d)))
1018  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
1019   
1020     + sum((o,d)$(ord(o) ne ord(d)), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *(ftext(o,d)
1021     - fext_aux(o,d)*log(n_airlines))) )
1022   
1023   
1024   
1025   
1026  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
1027   
1028  *    + 1e-3*sum((o,d), demand(o,d)
1029  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
1030   
1031  *   + 1e-3*sum((o,d), demand(o,d)
1032  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
1033  *    +1e-3*sum(i,deltast(i))
1034  *  + 1e-3*sum(i,
1035  *         1/(congestion_coefs_stations(i)*deltas(i) + epsi))
1036  *    +1e-3*sum((i,j),deltaat(i,j))
1037  *    + 1e-3*sum((i,j),
1038  *          1/(congestion_coefs_links(i,j)*deltaa(i,j) + epsi))
1039  ;
1040   
1041  * Objetivo total
1042  obj_def..
1043      obj =e= ul + 5e-2*gamma_*(pax + op + 1e3*exceed + 1e-6*bud);
1044   
1045  *---------------------*
1046  * Restricciones       *
1047  *---------------------*
1048   
1049   
1050  bud_avail..
1051      bud =l= budget;
1052   
1053  bud_final..
1054      ( sum(i, station_capacity_slope(i)*(s(i) + sh(i)))   + sum(i$((s_prev(i) > 0.01) or (sh_prev(i) > 0.01)), station_cost(i))
1055    + sum(i$(sh_prev(i) > 0.01), lam*hub_cost(i)))$(iter = niters) - exceed
1056      =l=
1057      budget
1058  ;
1059   
1060   
1061  profitability(o,d).. demand(o,d)*prices(o,d)*f(o,d) =g= sum((i,j),demand(o,d)*fij(i,j,o,d)*op_link_cost(i,j)/(a_nom*tau));
1062   
1063  * Simetría de a_prim
1064  link_sym(i,j)$(ord(i) ne ord(j))..  a(i,j) =e= a(j,i);
1065   
1066  * Capacidad de enlace: sum_{o,d} fij(i,j,o,d)*demand(o,d) <= tau*a(i,j)*a_nom
1067  link_cap(i,j)..
1068      sum((o,d), fij(i,j,o,d)*demand(o,d)) =l= a(i,j)*a_nom*tau;
1069   
1070   
1071   
1072  station_cap(i)..   sigma * (sum(j, a(j,i)) + sum(j, a(i,j))) =l= s(i) + sh(i);
1073   
1074  hub_connect_cap(i).. sigma * (sum( (o,d,j)$(ord(o)<>ord(i)),
1075      demand(o,d) * fij(i,j,o,d) / (a_nom * tau))  + sum( (o,d,j)$(ord(d)<>ord(i)),
1076      demand(o,d) * fij(j,i,o,d) / (a_nom * tau))) =l= sh(i);
1077   
1078   
1079  hub_direct_cap(o,d).. sigma * demand(o,d) * fij(o,d,o,d) / (a_nom * tau) =l= sh(o) + sh(d);
1080   
1081   
1082  * Límite total de links construidos/operativos
1083  tot_links..
1084      sum((i,j), a(i,j)) =l= a_max;
1085   
1086  * Relación f con flujos saliendo del origen
1087  link_flow_to_f(o,d)..
1088      sum(j, fij(o,j,o,d)) =e= f(o,d);
1089   
1090  * Conservación en nodos de origen (para k!=o): sum_out - sum_in = 1 - fext(o,k)
1091  flow_start(o,d)$(ord(o) ne ord(d))..
1092      ( sum(j, fij(o,j,o,d)) - sum(i, fij(i,o,o,d)) ) =e= 1 - fext(o,d);
1093   
1094  * Conservación en nodos destino (para k!=d): sum_out - sum_in = -1 + fext(k,d)
1095  flow_end(o,d)$(ord(o) ne ord(d))..
1096      ( sum(j, fij(d,j,o,d)) - sum(i, fij(i,d,o,d)) ) =e= -1 + fext(o,d);
1097   
1098  * Conservación en nodos intermedios i != o,d: sum_out - sum_in = 0
1099  flow_mid(i,o,d)$( (ord(o) ne ord(i)) and (ord(i) ne ord(d)) )..
1100      ( sum(j, fij(i,j,o,d)) - sum(j, fij(j,i,o,d)) ) =e= 0;
1101   
1102  * Zeros en diagonal y bloques prohibidos (replican fij(:,o,o,:) == 0, etc.)
1103  zero_diag_od(o)..           f(o,o)    =l= epsi;
1104  * fext(o,o)=0:
1105  zero_diag_odext(o)..           fext(o,o)    =l= epsi;
1106   
1107  * fij(i,i,*,*) = 0
1108  zero_fij_self(i,o,d)..      fij(i,i,o,d) =l= epsi;
1109   
1110  * fij(:,o,o,:) = 0  -> i cualquiera, j=o, o=o, d cualquiera
1111  zero_fij_origin(o,i,d)..    fij(i,o,o,d) =l= epsi;
1112   
1113  * fij(d,:,:,d) = 0  -> i=d, j cualquiera, o cualquiera, d=d
1114  zero_fij_dest(d,i,o)..      fij(d,i,o,d) =l= epsi;
1115   
1116  * Split: para o!=d, f + fext = 1
1117  split_choice(o,d)$(ord(o) ne ord(d))..
1118      f(o,d) + fext(o,d) =e= 1;
1119   
1120  * Enlaces no candidatesidatos forzados a 0: a_prim(i,j)=0 si ~(i,j) en candidates
1121  candidates_zero(i,j)$(not candidates(i,j))..
1122      a(i,j) =e= 0;
1123   
1124  * Fijaciones en la iteración final si previos pequeños (replica iter==niters … <=0.1)
1125  fix_s_at_zero(i)$( (s_prev(i) <= 0.01) and (iter = niters) )..
1126      s(i) =l= epsi;
1127   
1128  fix_sh_at_zero(i)$( (sh_prev(i) <= 0.01) and (iter = niters) )..
1129      sh(i) =l= epsi;
1130   
1131   
1132  def_f_aux(o,d).. f_aux(o,d) =e= f(o,d) + epsi_f;
1133  def_fext_aux(o,d).. fext_aux(o,d) =e= fext(o,d) + epsi_f;
1134   
1135   
1136  expconef(o,d)..  fy(o,d) =g= f_aux(o,d)*exp(fr(o,d)/f_aux(o,d));
1137   
1138   
