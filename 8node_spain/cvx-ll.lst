 896   
 897  Scalar n_airlines; n_airlines = 5;
 898   
 899  Scalar epsi_f; epsi_f =1e-6;
 900   
 901   
 902   
 903  display travel_time,link_cost,link_capacity_slope,prices,candidates,station_cost,station_capacity_slope,a_max, iter, niters, demand;
 904   
 905   
 906   
 907  *---------------------*
 908  * Variables           *
 909  *---------------------*
 910   
 911   
 912  Nonnegative Variable
 913      s(i),       sh(i),
 914      a(i,j),
 915      f(o,d),      fext(o,d), f_aux(o,d), fext_aux(o,d),
 916      fij(i,j,o,d), exceed
 917      ;
 918   
 919  Variable bud, op, ut, pax, obj, ft(o,d),ftext(o,d),fr(o,d),frext(o,d),fy(o,d),fyext(o,d), t(i);
 920   
 921   
 922   
 923  *---------------------*
 924  * Ecuaciones          *
 925  *---------------------*
 926  Equation
 927      bud_def      "definición de bud_obj"
 928      op_def       "definición de op_obj"
 929      pax_def      "definición de pax_obj"
 930      obj_def      "objetivo total"
 931      utility_def
 932   
 933      def_f_aux
 934      def_f_aux2
 935      def_fext_aux
 936      def_fext_aux2
 937   
 938      link_sym(i,j)
 939      prim_s_def(i)
 940      prim_a_def(i,j)
 941   
 942      link_cap(i,j)
 943      station_cap(i)
 944      hub_connect_cap(i)
 945      hub_direct_cap(o,d)
 946   
 947      tot_links
 948      link_flow_to_f(o,d)
 949   
 950      profitability(o,d)
 951   
 952      bud_avail
 953      bud_final
 954   
 955      flow_start(o,d)     "conservación en origen o para cada destino d != o"
 956      flow_end(o,d)       "conservación en destino d para cada origen o != d"
 957      flow_mid(i,o,d)     "conservación en nodos intermedios i != o,d"
 958   
 959      zero_diag_od(o)
 960      zero_fij_self(i,o,d)
 961      zero_fij_origin(o,i,d)
 962      zero_fij_dest(d,i,o)
 963      zero_diag_odext
 964   
 965      split_choice(o,d)
 966      candidates_zero(i,j)
 967   
 968      fix_s_at_zero(i)
 969      fix_sh_at_zero(i)
 970   
 971      expconef(o,d)
 972      exponefext(o,d)
 973      epigraphf(o,d)
 974      epigraphfext(o,d)
 975   
 976      def_deltasaux(i)
 977   
 978      def_deltaaaux(i,j)
 979   
 980      powercones(i)
 981      powerconea(i,j)
 982   
 983      cuad_cone(i)
 984   
 985  *rescap
 986  ;
 987   
 988  *---------------------*
 989  * Definición objetivo *
 990  *---------------------*
 991   
 992  * Presupuesto (bud): costes lineales + (si iter<niters) costes fijos aproximados
 993  bud_def..
 994      bud =e= sum(i, station_capacity_slope(i)*(s(i) + sh(i)))
 995           + sum(i,
 996                          station_cost(i)*(s(i)+sh(i))/((s_prev(i)+sh_prev(i))+epsi))
 997           + sum(i,
 998                          lam*hub_cost(i)*sh(i)/(sh_prev(i)+epsi)) ;
 999   
1000   
1001   
1002   
1003   
1004  * Operación (op): coste lineal de operar enlaces
1005  op_def..
1006      op =e= 1e-2*sum((i,j), op_link_cost(i,j) * a(i,j));
1007   
1008  * Pasajeros (pax): tiempos/precios en ruta y alternativas + entropías
1009  pax_def..
1010      pax =e= 1e-2*(
1011   
1012      + sum((o,d),alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) * (ft(o,d)))
1013  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
1014   
1015     + sum((o,d), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *(ftext(o,d)
1016     - fext_aux(o,d)*log(n_airlines))) );
1017   
1018   
1019  utility_def..
1020      ut =e= 1e-2*(
1021        sum((o,d)$(ord(o) ne ord(d)),
1022              alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *
1023             ( logit_coef*prices(o,d)*f(o,d) + sum((i,j), (travel_time(i,j))*fij(i,j,o,d)*logit_coef)))
1024   
1025      - sum((o,d), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d)
1026            * alt_utility(o,d)*fext(o,d)) );
1027   
1028   
1029   
1030  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
1031   
1032  *    + 1e-3*sum((o,d), demand(o,d)
1033  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
1034   
1035  *   + 1e-3*sum((o,d), demand(o,d)
1036  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
1037  *    +1e-3*sum(i,deltast(i))
1038  *  + 1e-3*sum(i,
1039  *         1/(congestion_coefs_stations(i)*deltas(i) + epsi))
1040  *    +1e-3*sum((i,j),deltaat(i,j))
1041  *    + 1e-3*sum((i,j),
1042  *          1/(congestion_coefs_links(i,j)*deltaa(i,j) + epsi))
1043  ;
1044   
1045  * Objetivo total
1046  obj_def..
1047      obj =e= pax + op + ut + 1e3*exceed + 1e-6*bud;
1048   
1049  *---------------------*
1050  * Restricciones       *
1051  *---------------------*
1052   
1053   
1054  bud_avail..
1055      bud =l= budget;
1056   
1057  bud_final..
1058      ( sum(i, station_capacity_slope(i)*(s(i) + sh(i)))   + sum(i$((s_prev(i) > 0.01) or (sh_prev(i) > 0.01)), station_cost(i))
1059    + sum(i$(sh_prev(i) > 0.01), lam*hub_cost(i)))$(iter = niters) - exceed
1060      =l=
1061      budget
1062  ;
1063   
1064   
1065  profitability(o,d).. demand(o,d)*prices(o,d)*f(o,d) =g= sum((i,j),demand(o,d)*fij(i,j,o,d)*op_link_cost(i,j)/(a_nom*tau));
1066   
1067  * Simetría de a_prim
1068  link_sym(i,j)$(ord(i) ne ord(j))..  a(i,j) =e= a(j,i);
1069   
1070  * Capacidad de enlace: sum_{o,d} fij(i,j,o,d)*demand(o,d) <= tau*a(i,j)*a_nom
1071  link_cap(i,j)..
1072      sum((o,d), fij(i,j,o,d)*demand(o,d)) =l= a(i,j)*a_nom*tau;
1073   
1074   
1075   
1076  station_cap(i)..   sigma * (sum(j, a(j,i)) + sum(j, a(i,j))) =l= s(i) + sh(i);
1077   
1078  hub_connect_cap(i).. sigma * (sum( (o,d,j)$(ord(o)<>ord(i)),
1079      demand(o,d) * fij(i,j,o,d) / (a_nom * tau))  + sum( (o,d,j)$(ord(d)<>ord(i)),
1080      demand(o,d) * fij(j,i,o,d) / (a_nom * tau))) =l= sh(i);
1081   
1082   
1083  hub_direct_cap(o,d).. sigma * demand(o,d) * fij(o,d,o,d) / (a_nom * tau) =l= sh(o) + sh(d);
1084   
1085   
1086  * Límite total de links construidos/operativos
1087  tot_links..
1088      sum((i,j), a(i,j)) =l= a_max;
1089   
1090  * Relación f con flujos saliendo del origen
1091  link_flow_to_f(o,d)..
1092      sum(j, fij(o,j,o,d)) =e= f(o,d);
1093   
1094  * Conservación en nodos de origen (para k!=o): sum_out - sum_in = 1 - fext(o,k)
1095  flow_start(o,d)$(ord(o) ne ord(d))..
1096      ( sum(j, fij(o,j,o,d)) - sum(i, fij(i,o,o,d)) ) =e= 1 - fext(o,d);
1097   
1098  * Conservación en nodos destino (para k!=d): sum_out - sum_in = -1 + fext(k,d)
1099  flow_end(o,d)$(ord(o) ne ord(d))..
1100      ( sum(j, fij(d,j,o,d)) - sum(i, fij(i,d,o,d)) ) =e= -1 + fext(o,d);
1101   
1102  * Conservación en nodos intermedios i != o,d: sum_out - sum_in = 0
1103  flow_mid(i,o,d)$( (ord(o) ne ord(i)) and (ord(i) ne ord(d)) )..
1104      ( sum(j, fij(i,j,o,d)) - sum(j, fij(j,i,o,d)) ) =e= 0;
1105   
1106  * Zeros en diagonal y bloques prohibidos (replican fij(:,o,o,:) == 0, etc.)
1107  zero_diag_od(o)..           f(o,o)    =l= epsi;
1108  * fext(o,o)=0:
1109  zero_diag_odext(o)..           fext(o,o)    =l= epsi;
1110   
1111  * fij(i,i,*,*) = 0
1112  zero_fij_self(i,o,d)..      fij(i,i,o,d) =l= epsi;
1113   
1114  * fij(:,o,o,:) = 0  -> i cualquiera, j=o, o=o, d cualquiera
1115  zero_fij_origin(o,i,d)..    fij(i,o,o,d) =l= epsi;
1116   
1117  * fij(d,:,:,d) = 0  -> i=d, j cualquiera, o cualquiera, d=d
1118  zero_fij_dest(d,i,o)..      fij(d,i,o,d) =l= epsi;
1119   
1120  * Split: para o!=d, f + fext = 1
1121  split_choice(o,d)$(ord(o) ne ord(d))..
1122      f(o,d) + fext(o,d) =e= 1;
1123   
1124  * Enlaces no candidatesidatos forzados a 0: a_prim(i,j)=0 si ~(i,j) en candidates
1125  candidates_zero(i,j)$(not candidates(i,j))..
1126      a(i,j) =e= 0;
1127   
1128  * Fijaciones en la iteración final si previos pequeños (replica iter==niters … <=0.1)
1129  fix_s_at_zero(i)$( (s_prev(i) <= 0.01) and (iter = niters) )..
1130      s(i) =l= epsi;
1131   
1132  fix_sh_at_zero(i)$( (sh_prev(i) <= 0.01) and (iter = niters) )..
1133      sh(i) =l= epsi;
1134   
1135   
1136  def_f_aux(o,d).. f_aux(o,d) =l= f(o,d) + epsi_f;
1137  def_f_aux2(o,d).. f_aux(o,d) =g= f(o,d) - epsi_f;
1138   
1139   
1140   
1141  def_fext_aux(o,d).. fext_aux(o,d) =l= fext(o,d) + epsi_f;
1142  def_fext_aux2(o,d).. fext_aux(o,d) =g= fext(o,d) - epsi_f;
1143   
1144   
1145  expconef(o,d)..  fy(o,d) =g= f_aux(o,d)*exp(fr(o,d)/f_aux(o,d));
1146   
1147   
