INCLUDE    C:\Users\freal\Desktop\HubSpokeNetworkDesign\8node_spain\export_txt\niters.txt
 887  10
 888  /;
 889   
 890  Scalar gamma_ /
INCLUDE    C:\Users\freal\Desktop\HubSpokeNetworkDesign\8node_spain\export_txt\gamma.txt
 892  20
 893  /;
 894   
 895  Scalar logit_coef; logit_coef = 0.02;
 896   
 897  Scalar n_airlines; n_airlines = 5;
 898   
 899  Scalar epsi_f; epsi_f =1e-6;
 900   
 901   
 902   
 903  display travel_time,link_cost,link_capacity_slope,prices,candidates,station_cost,station_capacity_slope,a_max, iter, niters, demand;
 904   
 905   
 906   
 907  *---------------------*
 908  * Variables           *
 909  *---------------------*
 910  Binary Variable
 911      sbin(i), shbin(i)
 912      ;
 913   
 914  Nonnegative Variable
 915      s(i),        s(i),    sh(i),
 916      a(i,j),
 917      f(o,d),      fext(o,d), f_aux(o,d), fext_aux(o,d),
 918      fij(i,j,o,d), exceed
 919      ;
 920   
 921  Variable bud, op, ut, pax, obj, ft(o,d),ftext(o,d),fr(o,d),frext(o,d),fy(o,d),fyext(o,d), t(i);
 922   
 923   
 924   
 925  *---------------------*
 926  * Ecuaciones          *
 927  *---------------------*
 928  Equation
 929      bud_def      "definición de bud_obj"
 930      op_def       "definición de op_obj"
 931      pax_def      "definición de pax_obj"
 932      obj_def      "objetivo total"
 933      utility_def
 934   
 935   
 936      def_f_aux
 937      def_f_aux2
 938      def_fext_aux
 939      def_fext_aux2
 940   
 941      link_sym(i,j)
 942      prim_s_def(i)
 943      prim_a_def(i,j)
 944   
 945      link_cap(i,j)
 946      station_cap(i)
 947      hub_connect_cap(i)
 948      hub_direct_cap(o,d)
 949   
 950      tot_links
 951      link_flow_to_f(o,d)
 952   
 953      profitability(o,d)
 954   
 955      bud_avail
 956      bud_final
 957   
 958      flow_start(o,d)     "conservación en origen o para cada destino d != o"
 959      flow_end(o,d)       "conservación en destino d para cada origen o != d"
 960      flow_mid(i,o,d)     "conservación en nodos intermedios i != o,d"
 961   
 962      zero_diag_od(o)
 963      zero_fij_self(i,o,d)
 964      zero_fij_origin(o,i,d)
 965      zero_fij_dest(d,i,o)
 966      zero_diag_odext
 967   
 968      split_choice(o,d)
 969      candidates_zero(i,j)
 970   
 971      fix_s_at_zero(i)
 972      fix_sh_at_zero(i)
 973   
 974      expconef(o,d)
 975      exponefext(o,d)
 976      epigraphf(o,d)
 977      epigraphfext(o,d)
 978   
 979      def_deltasaux(i)
 980   
 981      def_deltaaaux(i,j)
 982   
 983      powercones(i)
 984      powerconea(i,j)
 985   
 986      cuad_cone(i)
 987   
 988      bigms(i)
 989      bigmsh(i)
 990      srelsh(i)
 991   
 992  *rescap
 993  ;
 994   
 995  bigms(i)$(ord(i) gt 0).. s(i) =l= (1e6*sbin(i) );
 996  bigmsh(i).. sh(i) =l= 1e6*shbin(i);
 997  srelsh(i).. shbin(i) =l= sbin(i);
 998   
 999  *---------------------*
1000  * Definición objetivo *
1001  *---------------------*
1002   
1003  * Presupuesto (bud): costes lineales + (si iter<niters) costes fijos aproximados
1004  bud_def..
1005      bud =e= sum(i, station_capacity_slope(i)*(s(i) + sh(i)))
1006           + sum(i,
1007                          station_cost(i)*sbin(i))
1008           + sum(i,
1009                          lam*hub_cost(i)*shbin(i)) ;
1010   
1011   
1012   
1013   
1014  * Operación (op): coste lineal de operar enlaces
1015  op_def..
1016      op =e= 1e-2*sum((i,j), op_link_cost(i,j) * a(i,j));
1017   
1018  * Pasajeros (pax): tiempos/precios en ruta y alternativas + entropías
1019  pax_def..
1020      pax =e= 1e-2*(
1021   
1022      + sum((o,d),alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) * (ft(o,d)))
1023  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
1024   
1025     + sum((o,d), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *(ftext(o,d)
1026     - fext_aux(o,d)*log(n_airlines))) );
1027   
1028   
1029  utility_def..
1030      ut =e= 1e-2*(
1031        sum((o,d)$(ord(o) ne ord(d)),
1032              alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d) *
1033             ( logit_coef*prices(o,d)*f(o,d) + sum((i,j), (travel_time(i,j))*fij(i,j,o,d)*logit_coef)))
1034   
1035      - sum((o,d), alfa_od(o,d)*(prices(o,d)*demand(o,d))**beta_od(o,d)
1036            * alt_utility(o,d)*fext(o,d)) );
1037   
1038   
1039   
1040  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
1041   
1042  *    + 1e-3*sum((o,d), demand(o,d)
1043  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
1044   
1045  *   + 1e-3*sum((o,d), demand(o,d)
1046  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
1047  *    +1e-3*sum(i,deltast(i))
1048  *  + 1e-3*sum(i,
1049  *         1/(congestion_coefs_stations(i)*deltas(i) + epsi))
1050  *    +1e-3*sum((i,j),deltaat(i,j))
1051  *    + 1e-3*sum((i,j),
1052  *          1/(congestion_coefs_links(i,j)*deltaa(i,j) + epsi))
1053  ;
1054   
1055  * Objetivo total
1056  obj_def..
1057      obj =e= 1e-2*(pax + 1e-2*op + ut + 1e3*exceed);
1058   
1059  *---------------------*
1060  * Restricciones       *
1061  *---------------------*
1062   
1063   
1064  bud_avail..
1065      bud =l= budget;
1066   
1067  bud_final..
1068      bud
1069      =l=
1070      budget
1071  ;
1072   
1073   
1074  profitability(o,d).. demand(o,d)*prices(o,d)*f(o,d) =g= sum((i,j),demand(o,d)*fij(i,j,o,d)*op_link_cost(i,j)/(a_nom*tau));
1075   
1076  * Simetría de a_prim
1077  link_sym(i,j)$(ord(i) ne ord(j))..  a(i,j) =e= a(j,i);
1078   
1079  * Capacidad de enlace: sum_{o,d} fij(i,j,o,d)*demand(o,d) <= tau*a(i,j)*a_nom
1080  link_cap(i,j)..
1081      sum((o,d), fij(i,j,o,d)*demand(o,d)) =l= a(i,j)*a_nom*tau ;
1082   
1083   
1084   
1085  station_cap(i)..   sigma * (sum(j$ (ord(j) ne ord(i) ), a(j,i)) + sum(j$ (ord(j) ne ord(i) ), a(i,j))) =l= s(i) + sh(i) ;
1086   
1087  hub_connect_cap(i).. sigma * (sum( (o,d,j)$(ord(o)<>ord(i)),
1088      demand(o,d) * fij(i,j,o,d) / (a_nom * tau))  + sum( (o,d,j)$(ord(d)<>ord(i)),
1089      demand(o,d) * fij(j,i,o,d) / (a_nom * tau))) =l= sh(i);
1090   
1091   
1092  hub_direct_cap(o,d).. sigma * demand(o,d) * fij(o,d,o,d) / (a_nom * tau) =l= sh(o) + sh(d) ;
1093   
1094   
1095  * Límite total de links construidos/operativos
1096  tot_links..
1097      sum((i,j), a(i,j)) =l= a_max;
1098   
1099  * Relación f con flujos saliendo del origen
1100  link_flow_to_f(o,d)..
1101      sum(j, fij(o,j,o,d)) =e= f(o,d);
1102   
1103  * Conservación en nodos de origen (para k!=o): sum_out - sum_in = 1 - fext(o,k)
1104  flow_start(o,d)$(ord(o) ne ord(d))..
1105      ( sum(j, fij(o,j,o,d)) - sum(i, fij(i,o,o,d)) ) =e= 1 - fext(o,d);
1106   
1107  * Conservación en nodos destino (para k!=d): sum_out - sum_in = -1 + fext(k,d)
1108  flow_end(o,d)$(ord(o) ne ord(d))..
1109      ( sum(j, fij(d,j,o,d)) - sum(i, fij(i,d,o,d)) ) =e= -1 + fext(o,d);
1110   
1111  * Conservación en nodos intermedios i != o,d: sum_out - sum_in = 0
1112  flow_mid(i,o,d)$( (ord(o) ne ord(i)) and (ord(i) ne ord(d)) )..
1113      ( sum(j, fij(i,j,o,d)) - sum(j, fij(j,i,o,d)) ) =e= 0;
1114   
1115  * Zeros en diagonal y bloques prohibidos (replican fij(:,o,o,:) == 0, etc.)
1116  zero_diag_od(o)..           f(o,o)    =l= 0;
1117  * fext(o,o)=0:
1118  zero_diag_odext(o)..           fext(o,o)    =l= 0;
1119   
1120  * fij(i,i,*,*) = 0
1121  zero_fij_self(i,o,d)..      fij(i,i,o,d) =l= 0;
1122   
1123  * fij(:,o,o,:) = 0  -> i cualquiera, j=o, o=o, d cualquiera
1124  zero_fij_origin(o,i,d)..    fij(i,o,o,d) =l= 0;
1125   
1126  * fij(d,:,:,d) = 0  -> i=d, j cualquiera, o cualquiera, d=d
1127  zero_fij_dest(d,i,o)..      fij(d,i,o,d) =l= 0;
1128   
1129  * Split: para o!=d, f + fext = 1
1130  split_choice(o,d)$(ord(o) ne ord(d))..
1131      f(o,d) + fext(o,d) =e= 1;
1132   
1133  * Enlaces no candidatesidatos forzados a 0: a_prim(i,j)=0 si ~(i,j) en candidates
1134  candidates_zero(i,j)$(not candidates(i,j))..
1135      a(i,j) =e= 0;
1136   
1137  * Fijaciones en la iteración final si previos pequeños (replica iter==niters … <=0.1)
1138  fix_s_at_zero(i)$( (s_prev(i) <= 0.01) and (iter = niters) )..
1139      s(i) =l= epsi;
1140   
1141  fix_sh_at_zero(i)$( (sh_prev(i) <= 0.01) and (iter = niters) )..
1142      sh(i) =l= epsi;
1143   
1144   
1145  def_f_aux(o,d).. f_aux(o,d) =l= f(o,d) + epsi_f;
1146  def_f_aux2(o,d).. f_aux(o,d) =g= f(o,d) - epsi_f;
1147   
1148   
1149   
1150  def_fext_aux(o,d).. fext_aux(o,d) =l= fext(o,d) + epsi_f;
1151  def_fext_aux2(o,d).. fext_aux(o,d) =g= fext(o,d) - epsi_f;
1152   
