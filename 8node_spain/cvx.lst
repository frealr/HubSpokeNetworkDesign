 620      prim_s_def(i)
 621      prim_a_def(i,j)
 622   
 623      link_cap(i,j)
 624      station_cap(i)
 625      hub_connect_cap(i)
 626      hub_direct_cap(o,d)
 627   
 628      tot_links
 629      link_flow_to_f(o,d)
 630   
 631      profitability(o,d)
 632   
 633      bud_avail
 634      bud_final
 635   
 636      flow_start(o,d)     "conservación en origen o para cada destino d != o"
 637      flow_end(o,d)       "conservación en destino d para cada origen o != d"
 638      flow_mid(i,o,d)     "conservación en nodos intermedios i != o,d"
 639   
 640      zero_diag_od(o)
 641      zero_fij_self(i,o,d)
 642      zero_fij_origin(o,i,d)
 643      zero_fij_dest(d,i,o)
 644      zero_diag_odext
 645   
 646      split_choice(o,d)
 647      candidates_zero(i,j)
 648   
 649      fix_s_at_zero(i)
 650      fix_sh_at_zero(i)
 651   
 652      expconef(o,d)
 653      exponefext(o,d)
 654      epigraphf(o,d)
 655      epigraphfext(o,d)
 656   
 657      def_deltasaux(i)
 658      def_deltaaaux(i,j)
 659      powercones(i)
 660      powerconea(i,j)
 661   
 662  *rescap
 663  ;
 664   
 665  *---------------------*
 666  * Definición objetivo *
 667  *---------------------*
 668   
 669  * Presupuesto (bud): costes lineales + (si iter<niters) costes fijos aproximados
 670  bud_def..
 671      bud =e= sum(i, station_capacity_slope(i)*(s(i) + sh(i)))
 672           + sum(i,
 673                          station_cost(i)*(s(i)+sh(i))/((s_prev(i)+sh_prev(i))+epsi))
 674           + sum(i,
 675                          lam*hub_cost(i)*sh(i)/(sh_prev(i)+epsi));
 676   
 677   
 678   
 679   
 680   
 681  * Operación (op): coste lineal de operar enlaces
 682  op_def..
 683      op =e= sum((i,j), op_link_cost(i,j) * a(i,j));
 684   
 685  * Pasajeros (pax): tiempos/precios en ruta y alternativas + entropías
 686  pax_def..
 687      pax =e= 1e-2*(
 688        sum((o,d),
 689              (prices(o,d)*demand(o,d))**2 *
 690             ( logit_coef*prices(o,d)*f(o,d) + sum((i,j), (travel_time(i,j))*fij(i,j,o,d)*logit_coef)))
 691   
 692      - sum((o,d), (prices(o,d)*demand(o,d))**2
 693            * alt_utility(o,d)*fext(o,d))
 694   
 695      + sum((o,d),(prices(o,d)*demand(o,d))**2 * (ft(o,d)))
 696  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
 697   
 698     + sum((o,d), (prices(o,d)*demand(o,d))**2 *(ftext(o,d)
 699     - fext_aux(o,d)*log(n_airlines))) )
 700   
 701   
 702   
 703   
 704  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
 705   
 706  *    + 1e-3*sum((o,d), demand(o,d)
 707  *          * (  ( f(o,d)*log(f(o,d)) - f(o,d) ) ))
 708   
 709  *   + 1e-3*sum((o,d), demand(o,d)
 710  *          * (  ( fext(o,d)*log(fext(o,d)) - fext(o,d) ) ))
 711  *    +1e-3*sum(i,deltast(i))
 712  *  + 1e-3*sum(i,
 713  *         1/(congestion_coefs_stations(i)*deltas(i) + epsi))
 714  *    +1e-3*sum((i,j),deltaat(i,j))
 715  *    + 1e-3*sum((i,j),
 716  *          1/(congestion_coefs_links(i,j)*deltaa(i,j) + epsi))
 717  ;
 718   
 719  * Objetivo total
 720  obj_def..
 721      obj =e= alfa*pax  + op  + 1e3*exceed + 1e-2*bud;
 722   
 723  *---------------------*
 724  * Restricciones       *
 725  *---------------------*
 726   
 727   
 728  bud_avail..
 729      bud$(iter < niters) =l= budget;
 730   
 731  bud_final..
 732      ( sum(i, station_capacity_slope(i)*(s(i) + sh(i)))   + sum(i$((s_prev(i) > 0.1) or (sh_prev(i) > 0.1)), station_cost(i))
 733    + sum(i$(sh_prev(i) > 0.1), lam*hub_cost(i)))$(iter = niters) - exceed
 734      =l=
 735      budget
 736  ;
 737   
 738   
 739  profitability(o,d).. demand(o,d)*prices(o,d)*f(o,d) =g= sum((i,j),demand(o,d)*fij(i,j,o,d)*op_link_cost(i,j)/(a_nom*tau));
 740   
 741  * Simetría de a_prim
 742  link_sym(i,j)$(ord(i) ne ord(j))..  a(i,j) =e= a(j,i);
 743   
 744  * Capacidad de enlace: sum_{o,d} fij(i,j,o,d)*demand(o,d) <= tau*a(i,j)*a_nom
 745  link_cap(i,j)..
 746      sum((o,d), fij(i,j,o,d)*demand(o,d)) =l= a(i,j)*a_nom*tau;
 747   
 748   
 749   
 750  station_cap(i)..   sigma * (sum(j, a(j,i)) + sum(j, a(i,j))) =l= s(i) + sh(i);
 751   
 752  hub_connect_cap(i).. sigma * (sum( (o,d,j)$(ord(o)<>ord(i)),
 753      demand(o,d) * fij(i,j,o,d) / (a_nom * tau))  + sum( (o,d,j)$(ord(d)<>ord(i)),
 754      demand(o,d) * fij(j,i,o,d) / (a_nom * tau))) =l= sh(i);
 755   
 756   
 757  hub_direct_cap(o,d).. sigma * demand(o,d) * fij(o,d,o,d) / (a_nom * tau) =l= sh(o) + sh(d);
 758   
 759   
 760  * Límite total de links construidos/operativos
 761  tot_links..
 762      sum((i,j), a(i,j)) =l= a_max;
 763   
 764  * Relación f con flujos saliendo del origen
 765  link_flow_to_f(o,d)..
 766      sum(j, fij(o,j,o,d)) =e= f(o,d);
 767   
 768  * Conservación en nodos de origen (para k!=o): sum_out - sum_in = 1 - fext(o,k)
 769  flow_start(o,d)$(ord(o) ne ord(d))..
 770      ( sum(j, fij(o,j,o,d)) - sum(i, fij(i,o,o,d)) ) =e= 1 - fext(o,d);
 771   
 772  * Conservación en nodos destino (para k!=d): sum_out - sum_in = -1 + fext(k,d)
 773  flow_end(o,d)$(ord(o) ne ord(d))..
 774      ( sum(j, fij(d,j,o,d)) - sum(i, fij(i,d,o,d)) ) =e= -1 + fext(o,d);
 775   
 776  * Conservación en nodos intermedios i != o,d: sum_out - sum_in = 0
 777  flow_mid(i,o,d)$( (ord(o) ne ord(i)) and (ord(i) ne ord(d)) )..
 778      ( sum(j, fij(i,j,o,d)) - sum(j, fij(j,i,o,d)) ) =e= 0;
 779   
 780  * Zeros en diagonal y bloques prohibidos (replican fij(:,o,o,:) == 0, etc.)
 781  zero_diag_od(o)..           f(o,o)    =l= epsi;
 782  * fext(o,o)=0:
 783  zero_diag_odext(o)..           fext(o,o)    =l= epsi;
 784   
 785  * fij(i,i,*,*) = 0
 786  zero_fij_self(i,o,d)..      fij(i,i,o,d) =l= epsi;
 787   
 788  * fij(:,o,o,:) = 0  -> i cualquiera, j=o, o=o, d cualquiera
 789  zero_fij_origin(o,i,d)..    fij(i,o,o,d) =l= epsi;
 790   
 791  * fij(d,:,:,d) = 0  -> i=d, j cualquiera, o cualquiera, d=d
 792  zero_fij_dest(d,i,o)..      fij(d,i,o,d) =l= epsi;
 793   
 794  * Split: para o!=d, f + fext = 1
 795  split_choice(o,d)$(ord(o) ne ord(d))..
 796      f(o,d) + fext(o,d) =e= 1;
 797   
 798  * Enlaces no candidatesidatos forzados a 0: a_prim(i,j)=0 si ~(i,j) en candidates
 799  candidates_zero(i,j)$(not candidates(i,j))..
 800      a(i,j) =e= 0;
 801   
 802  * Fijaciones en la iteración final si previos pequeños (replica iter==niters … <=0.1)
 803  fix_s_at_zero(i)$( (s_prev(i) <= 0.1) and (iter = niters) )..
 804      s(i) =l= epsi;
 805   
 806  fix_sh_at_zero(i)$( (sh_prev(i) <= 0.1) and (iter = niters) )..
 807      sh(i) =l= epsi;
 808   
 809   
 810  def_f_aux(o,d).. f_aux(o,d) =e= f(o,d) + epsi_f;
 811  def_fext_aux(o,d).. fext_aux(o,d) =e= fext(o,d) + epsi_f;
 812   
 813   
 814  expconef(o,d)..  fy(o,d) =g= f_aux(o,d)*exp(fr(o,d)/f_aux(o,d));
 815   
 816   
 817  exponefext(o,d)..  fyext(o,d) =g= fext_aux(o,d)*exp(frext(o,d)/fext_aux(o,d));
 818   
 819  epigraphf(o,d)..  ft(o,d) =g= -fr(o,d)-f_aux(o,d);
 820   
 821  epigraphfext(o,d)..  ftext(o,d) =g= -frext(o,d)-fext_aux(o,d);
 822   
 823  *rescap(i,j,o,d).. fij(i,j,o,d) =l= capa(i,j);
 824   
 825  *---------------------*
 826  * Bounds básicas      *
 827  *---------------------*
 828  * Ya son positivas; si quieres forzar [0,1] también para f,fext,fij ya está con .up=1
 829  * Para a, s, etc., sin cota superior explícita (ajústalas si procede)
 830   
