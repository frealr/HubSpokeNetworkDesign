2732   
2733   
2734  Scalars tau, sigma, a_nom, a_max, M, n_airlines;
2735  tau = 0.85;
2736  sigma = 0.3;
2737  a_nom = 171;
2738  a_max = 1e7;
2739  M = 1e5;
2740  n_airlines = 5;
2741   
2742  Scalar n; n = card(i);
2743   
2744  Scalar epsi; epsi = 1e-3;
2745   
2746  Scalar lam /
INCLUDE    C:\Users\freal\Desktop\HubSpokeNetworkDesign\8node_spain\export_txt\lam.txt
2748  4
2749  /;
2750   
2751  Scalar alfa /
INCLUDE    C:\Users\freal\Desktop\HubSpokeNetworkDesign\8node_spain\export_txt\alfa.txt
2753  5.000000e-01
2754  /;
2755   
2756   
2757  Scalar dm_pax /
INCLUDE    C:\Users\freal\Desktop\HubSpokeNetworkDesign\8node_spain\export_txt\dm_pax.txt
2759  1.000000e-02
2760  /;
2761   
2762  Scalar dm_op /
INCLUDE    C:\Users\freal\Desktop\HubSpokeNetworkDesign\8node_spain\export_txt\dm_op.txt
2764  8.000000e-03
2765  /;
2766   
2767  Scalar budget /
INCLUDE    C:\Users\freal\Desktop\HubSpokeNetworkDesign\8node_spain\export_txt\budget.txt
2769  100000
2770  /;
2771   
2772  Scalar nom_bud
2773  /
INCLUDE    C:\Users\freal\Desktop\HubSpokeNetworkDesign\8node_spain\export_txt\budget.txt
2775  100000
2776  /;
2777   
2778  Scalar logit_coef; logit_coef = 0.02;
2779   
2780   
2781   
2782  display travel_time,link_cost,link_capacity_slope,prices,candidates,station_cost,station_capacity_slope,a_max,demand;
2783   
2784   
2785  * ---------- Variables ----------
2786  Variables
2787      obj, op_obj, pax_obj, xlen(o,d), budvar
2788  ;
2789   
2790  Positive Variables
2791      s(i), sh(i), a(i,j), f(o,d), fext(o,d), zij(i,j,o,d),
2792      delta(seg,o,d), ghat(o,d)
2793  ;
2794   
2795  Binary Variables
2796      s_bin(i),
2797      sh_bin(i),
2798      a_bin(i,i),
2799      z(i,i),
2800      fij(i,i,i,i),
2801      alfaseg(seg,o,d)
2802  ;
2803   
2804   
2805  * Cotas superiores
2806  f.up(i,j)       = 1;
2807  f.lo(i,j)       = 0;
2808  fext.up(i,j)    = 1;
2809  fext.lo(i,j)    = 0;
2810  zij.up(i,j,o,d) = 1;
2811  zij.lo(i,j,o,d) = 0;
2812   
2813  * ---------- Ecuaciones ----------
2814  Equations
2815      def_bud, def_op_obj, def_pax_obj, def_obj,
2816      bigM_s, bigM_sh, bigM_a, relssh, bud_avail,
2817      link_cap, station_cap, hub_connect_cap, hub_direct_cap,
2818      tot_links, link_sym,
2819      fij_od_flow, fij_do_flow, fij_trans
2820      diag_zero_fo, fij_zero_diag, fij_zero_oo, fij_zero_dd
2821      split_fd, f_leq_Mz
2822      cand_zero
2823      zij_bigM_lb, zij_leq_f, zij_leq_Mfij
2824      def_xlen, alfaseg_sum, delta_bound,delta_bound_last, xlen_interp, slice_bound, ghat_interp, f_leq_ghat
2825  ;
2826   
2827   
2828  def_bud.. budvar =e= sum(i, station_capacity_slope(i)*(s(i)+sh(i)))
2829           + sum(i,
2830                          station_cost(i)*s_bin(i))
2831           + lam*sum(i,
2832                          hub_cost(i)*sh_bin(i));
2833   
2834  * ---------- Objetivo ----------
2835  def_op_obj..
2836      op_obj =e=  sum((i,j), op_link_cost(i,j) * a(i,j));
2837   
2838  def_pax_obj..
2839      pax_obj =e= - sum((o,d), prices(o,d) * demand(o,d) * f(o,d));
2840   
2841  def_obj..
2842      obj =e=  pax_obj + op_obj + 1e-4*sum(i, (1.0001*s(i)+sh(i)+s_bin(i)+sh_bin(i)));
2843   
2844   
2845  * ---------- Restricciones de infraestructura ----------
2846  *sprim_link(i)..          s_prim(i)   =e= s(i) + delta_s(i);
2847  *aprim_link(i,j)..        a_prim(i,j) =e= a(i,j) + delta_a(i,j);
2848   
2849  bigM_s(i)..              s(i)   =l= M * s_bin(i);
2850  bigM_sh(i)..             sh(i)  =l= M * sh_bin(i);
2851  bigM_a(i,j)..            a(i,j) =l= M * a_bin(i,j);
2852  relssh(i)..              sh_bin(i) =l= s_bin(i);
2853   
2854  bud_avail..
2855      budvar =l= budget;
2856   
2857  link_cap(i,j)..
2858       sum((o,d), zij(i,j,o,d) * demand(o,d)) =l= a(i,j) * a_nom * tau;
2859   
2860  station_cap(i)..   sigma * (sum(j, a(j,i)) + sum(j, a(i,j))) =l= s(i) + sh(i);
2861   
2862  hub_connect_cap(i).. sigma * (sum( (o,d,j)$(ord(o)<>ord(i)),
2863      demand(o,d) * zij(i,j,o,d) / (a_nom * tau))  + sum( (o,d,j)$(ord(d)<>ord(i)),
2864      demand(o,d) * zij(j,i,o,d) / (a_nom * tau))) =l= sh(i);
2865   
2866  hub_direct_cap(o,d).. sigma * demand(o,d) * zij(o,d,o,d) / (a_nom * tau) =l= sh(o) + sh(d);
2867   
2868  tot_links.. sum((i,j), a(i,j)) =l= a_max;
2869   
2870  link_sym(i,j).. a(i,j) =e= a(j,i);
2871   
2872  * ---------- Restricciones de flujo ----------
2873  fij_od_flow(o,d)$(ord(o)<>ord(d))..
2874      sum(j$(ord(j)<>ord(o)), fij(o,j,o,d))
2875    - sum(i$(ord(i)<>ord(o)), fij(i,o,o,d))
2876    =e= z(o,d);
2877   
2878  fij_do_flow(o,d)$(ord(o)<>ord(d))..
2879      sum(j$(ord(j)<>ord(d)), fij(d,j,o,d))
2880    - sum(i$(ord(i)<>ord(d)), fij(i,d,o,d))
2881    =e= -z(o,d);
2882   
2883  fij_trans(i,o,d)$(ord(i)<>ord(o) and ord(i)<>ord(d))..
2884      sum(j$(ord(j)<>ord(i)), fij(i,j,o,d))
2885    - sum(ii$(ord(ii)<>ord(i)), fij(ii,i,o,d))
2886    =e= 0;
2887   
2888  diag_zero_fo(o)..            f(o,o) + fext(o,o) =e= 0;
2889  fij_zero_diag(i,o,d)..       fij(i,i,o,d) =e= 0;
2890  fij_zero_oo(o,i,d)..         fij(i,o,o,d) =e= 0;
2891  fij_zero_dd(d,i,o)..         fij(d,i,o,d) =e= 0;
2892   
2893  split_fd(o,d)$(ord(o)<>ord(d))..  f(o,d) + fext(o,d) =e= 1;
2894   
2895  f_leq_Mz(o,d)$(ord(o)<>ord(d))..  f(o,d) =l=  z(o,d);
2896   
2897  cand_zero(i,j)$(candidates(i,j)=0)..  a(i,j) =e= 0;
2898   
2899  zij_bigM_lb(i,j,o,d)..  zij(i,j,o,d) =g= f(o,d) - (1 - fij(i,j,o,d));
2900  zij_leq_f(i,j,o,d)..    zij(i,j,o,d) =l= f(o,d);
2901  zij_leq_Mfij(i,j,o,d).. zij(i,j,o,d) =l= fij(i,j,o,d);
2902   
2903  * ---------- PWL con convex combination + binarios ----------
2904  def_xlen(o,d)$(ord(o)<>ord(d))..
2905      xlen(o,d) =e= sum((i,j), fij(i,j,o,d) * logit_coef*(-travel_time(i,j))) + z(o,d)*logit_coef*(-prices(o,d));
2906   
2907  alfaseg_sum(o,d)$(ord(o)<>ord(d)).. sum(seg,alfaseg(seg,o,d)) =e= 1;
2908   
2909  delta_bound(seg,o,d)$((ord(o)<>ord(d)) and (ord(seg) lt card(seg))).. delta(seg,o,d) =l= alfaseg(seg,o,d)*(b(seg+1,o,d)-b(seg,o,d));
2910   
2911  delta_bound_last(seg,o,d)$(ord(seg)=card(seg))..  delta(seg,o,d) =l= alfaseg(seg,o,d)*(-b(seg,o,d));
2912   
2913  xlen_interp(o,d)$(ord(o)<>ord(d)).. xlen(o,d) =e= sum(seg,alfaseg(seg,o,d)*b(seg,o,d) + delta(seg,o,d));
2914   
2915  slice_bound(seg,o,d)$((ord(seg) lt card(seg)) and (ord(o)<>ord(d)) ).. b(seg,o,d) + delta(seg,o,d) =l= b(seg+1,o,d);
2916   
2917  ghat_interp(o,d)$(ord(o)<>ord(d)).. ghat(o,d) =e= sum(seg,alfaseg(seg,o,d)*bord(seg,o,d) + mreg(seg,o,d)*delta(seg,o,d));
2918   
2919  f_leq_ghat(o,d)$(ord(o)<>ord(d))..     f(o,d) =l= ghat(o,d);
2920   
2921   
2922  * ---------- Modelo y resolución ----------
2923  Model netdesign /
2924      def_bud,
2925      def_op_obj,
2926      def_pax_obj,
2927      def_obj,
2928      bigM_s,
2929      bigM_sh,
2930      bigM_a,
2931      relssh,
2932      bud_avail,
2933      link_cap,
2934      station_cap,
2935      hub_connect_cap, hub_direct_cap,
2936      tot_links,
2937      link_sym,
2938      fij_od_flow, fij_do_flow, fij_trans
2939      diag_zero_fo, fij_zero_diag, fij_zero_oo, fij_zero_dd
2940      split_fd, f_leq_Mz
